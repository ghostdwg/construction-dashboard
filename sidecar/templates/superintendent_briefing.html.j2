<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Superintendent Briefing — {{ bid.projectName }}</title>
  <style>
    /* ── Page setup ─────────────────────────────────────────────────────────── */
    @page {
      size: letter;
      margin: 0.75in;
      @bottom-center {
        content: "{{ bid.projectName }} · Superintendent Briefing · Page " counter(page) " of " counter(pages);
        font-size: 8pt;
        color: #6b7280;
        font-family: Arial, Helvetica, sans-serif;
      }
    }

    /* ── Base ────────────────────────────────────────────────────────────────── */
    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      color: #1f2937;
      margin: 0;
      padding: 0;
    }

    /* ── Page header ─────────────────────────────────────────────────────────── */
    .page-header {
      background-color: #1a1a2e;
      color: #ffffff;
      padding: 14pt 16pt;
      margin-bottom: 16pt;
    }
    .page-header table {
      width: 100%;
      border-collapse: collapse;
    }
    .page-header td {
      padding: 0;
      vertical-align: top;
    }
    .page-header .project-name {
      font-size: 15pt;
      font-weight: bold;
      letter-spacing: 0.3pt;
    }
    .page-header .project-location {
      font-size: 9pt;
      color: #d1d5db;
      margin-top: 2pt;
    }
    .page-header .meta-right {
      text-align: right;
    }
    .page-header .as-of-label {
      font-size: 8pt;
      color: #9ca3af;
      text-transform: uppercase;
      letter-spacing: 0.5pt;
    }
    .page-header .as-of-value {
      font-size: 11pt;
      font-weight: bold;
      margin-top: 2pt;
    }
    .page-header .lookahead-label {
      font-size: 8pt;
      color: #9ca3af;
      margin-top: 6pt;
    }
    .page-header .generated-at {
      font-size: 7.5pt;
      color: #6b7280;
      margin-top: 10pt;
    }

    /* ── Section headings ────────────────────────────────────────────────────── */
    .section-heading {
      font-size: 11pt;
      font-weight: bold;
      color: #1a1a2e;
      border-bottom: 2pt solid #1a1a2e;
      padding-bottom: 3pt;
      margin-top: 16pt;
      margin-bottom: 8pt;
    }
    .subsection-heading {
      font-size: 9pt;
      font-weight: bold;
      color: #374151;
      background-color: #f3f4f6;
      padding: 4pt 6pt;
      margin-top: 8pt;
      margin-bottom: 4pt;
    }

    /* ── Tables ──────────────────────────────────────────────────────────────── */
    table.data-table {
      width: 100%;
      border-collapse: collapse;
      page-break-inside: avoid;
      margin-bottom: 6pt;
    }
    table.data-table thead tr {
      background-color: #e5e7eb;
    }
    table.data-table thead th {
      font-size: 7.5pt;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.4pt;
      color: #4b5563;
      padding: 4pt 6pt;
      text-align: left;
      border-bottom: 1pt solid #d1d5db;
    }
    table.data-table tbody tr {
      border-bottom: 0.5pt solid #e5e7eb;
    }
    table.data-table tbody tr:nth-child(even) {
      background-color: #f9fafb;
    }
    table.data-table tbody td {
      padding: 4pt 6pt;
      vertical-align: top;
      font-size: 8.5pt;
    }

    /* Row color coding for action items */
    tr.row-critical {
      background-color: #fef2f2 !important;
    }
    tr.row-high {
      background-color: #fffbeb !important;
    }

    /* ── Status badges ────────────────────────────────────────────────────────── */
    .badge {
      display: inline;
      padding: 1pt 4pt;
      border-radius: 3pt;
      font-size: 7.5pt;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.3pt;
    }
    .badge-overdue  { background-color: #fef2f2; color: #991b1b; }
    .badge-review   { background-color: #eff6ff; color: #1e40af; }
    .badge-approach { background-color: #fffbeb; color: #854d0e; }
    .badge-critical { background-color: #fef2f2; color: #991b1b; }
    .badge-high     { background-color: #fffbeb; color: #854d0e; }
    .badge-medium   { background-color: #f0fdf4; color: #166534; }
    .badge-low      { background-color: #f3f4f6; color: #374151; }
    .badge-progress { background-color: #eff6ff; color: #1e40af; }
    .badge-complete { background-color: #f0fdf4; color: #166534; }
    .badge-hold     { background-color: #fff7ed; color: #9a3412; }

    /* ── Empty state ─────────────────────────────────────────────────────────── */
    .empty-row td {
      font-style: italic;
      color: #9ca3af;
      padding: 5pt 6pt;
    }

    /* ── Risk flags ──────────────────────────────────────────────────────────── */
    .risk-block {
      border-left: 3pt solid #991b1b;
      background-color: #fef2f2;
      padding: 5pt 8pt;
      margin-bottom: 5pt;
      page-break-inside: avoid;
    }
    .risk-text {
      font-size: 8.5pt;
      color: #1f2937;
    }

    /* ── No submittals notice ─────────────────────────────────────────────────── */
    .notice {
      font-style: italic;
      color: #6b7280;
      font-size: 8.5pt;
      padding: 4pt 0;
    }
  </style>
</head>
<body>

<!-- ── Page Header ──────────────────────────────────────────────────────────── -->
<div class="page-header">
  <table>
    <tr>
      <td style="width: 65%;">
        <div class="project-name">{{ bid.projectName }}</div>
        {% if bid.location %}
        <div class="project-location">{{ bid.location }}</div>
        {% endif %}
      </td>
      <td class="meta-right" style="width: 35%;">
        <div class="as-of-label">Superintendent Briefing</div>
        <div class="as-of-value">As of {{ as_of_date_fmt }}</div>
        <div class="lookahead-label">{{ lookahead_days }}-day lookahead window</div>
      </td>
    </tr>
  </table>
  <div class="generated-at">Generated {{ generated_at_fmt }}</div>
</div>


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- Section 1: Schedule Summary                                                 -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="section-heading">1. Schedule Summary</div>

<!-- 1a: Overdue Activities -->
<div class="subsection-heading">Overdue Activities</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width: 40%;">Activity</th>
      <th style="width: 20%;">Trade</th>
      <th style="width: 20%;">Planned Finish</th>
      <th style="width: 20%;">Status</th>
    </tr>
  </thead>
  <tbody>
    {% if schedule.overdue %}
      {% for a in schedule.overdue %}
      <tr>
        <td>{{ a.name }}{% if a.isMilestone %} <span class="badge badge-complete">Milestone</span>{% endif %}</td>
        <td>{{ a.trade or "—" }}</td>
        <td>{{ a.finishDate | date_fmt }}</td>
        <td><span class="badge badge-overdue">Overdue</span></td>
      </tr>
      {% endfor %}
    {% else %}
      <tr class="empty-row"><td colspan="4">None</td></tr>
    {% endif %}
  </tbody>
</table>

<!-- 1b: This Week -->
<div class="subsection-heading">This Week</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width: 38%;">Activity</th>
      <th style="width: 18%;">Trade</th>
      <th style="width: 15%;">Start</th>
      <th style="width: 15%;">Finish</th>
      <th style="width: 14%;">% Done</th>
    </tr>
  </thead>
  <tbody>
    {% if schedule.thisWeek %}
      {% for a in schedule.thisWeek %}
      <tr>
        <td>{{ a.name }}{% if a.isMilestone %} <span class="badge badge-complete">Milestone</span>{% endif %}</td>
        <td>{{ a.trade or "—" }}</td>
        <td>{{ a.startDate | date_fmt }}</td>
        <td>{{ a.finishDate | date_fmt }}</td>
        <td>
          {% if a.status == "in_progress" %}
            <span class="badge badge-progress">{{ (a.percentComplete or 0) | int }}%</span>
          {% elif a.status == "complete" %}
            <span class="badge badge-complete">Done</span>
          {% elif a.status == "on_hold" %}
            <span class="badge badge-hold">Hold</span>
          {% else %}
            <span class="badge badge-low">{{ (a.percentComplete or 0) | int }}%</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    {% else %}
      <tr class="empty-row"><td colspan="5">None</td></tr>
    {% endif %}
  </tbody>
</table>

<!-- 1c: N-Day Lookahead -->
<div class="subsection-heading">{{ lookahead_days }}-Day Lookahead</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width: 38%;">Activity</th>
      <th style="width: 18%;">Trade</th>
      <th style="width: 15%;">Start</th>
      <th style="width: 15%;">Finish</th>
      <th style="width: 14%;">% Done</th>
    </tr>
  </thead>
  <tbody>
    {% if schedule.lookahead %}
      {% for a in schedule.lookahead %}
      <tr>
        <td>{{ a.name }}{% if a.isMilestone %} <span class="badge badge-complete">Milestone</span>{% endif %}</td>
        <td>{{ a.trade or "—" }}</td>
        <td>{{ a.startDate | date_fmt }}</td>
        <td>{{ a.finishDate | date_fmt }}</td>
        <td><span class="badge badge-low">{{ (a.percentComplete or 0) | int }}%</span></td>
      </tr>
      {% endfor %}
    {% else %}
      <tr class="empty-row"><td colspan="5">None</td></tr>
    {% endif %}
  </tbody>
</table>


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- Section 2: Submittals                                                       -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="section-heading">2. Submittals</div>

{% set overdue_subs    = submittals | selectattr("isOverdue",    "equalto", true)  | list %}
{% set review_subs     = submittals | selectattr("isOverdue",    "equalto", false)
                                    | selectattr("status",       "in", ["RECEIVED","UNDER_REVIEW"]) | list %}
{% set approach_subs   = submittals | selectattr("isApproaching","equalto", true)
                                    | selectattr("isOverdue",    "equalto", false)
                                    | selectattr("status",       "nin", ["RECEIVED","UNDER_REVIEW"]) | list %}

{% if not overdue_subs and not review_subs and not approach_subs %}
  <p class="notice">No submittals requiring attention.</p>
{% else %}

<!-- 2a: Overdue Submissions -->
{% if overdue_subs %}
<div class="subsection-heading">Overdue Submissions</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width: 38%;">Title</th>
      <th style="width: 18%;">Trade</th>
      <th style="width: 14%;">Type</th>
      <th style="width: 15%;">Submit By</th>
      <th style="width: 15%;">Status</th>
    </tr>
  </thead>
  <tbody>
    {% for s in overdue_subs %}
    <tr>
      <td>{{ s.title }}</td>
      <td>{{ s.trade or "—" }}</td>
      <td>{{ s.type or "OTHER" }}</td>
      <td>{{ (s.submitByDate or s.requiredBy) | date_fmt }}</td>
      <td><span class="badge badge-overdue">{{ s.status }}</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

<!-- 2b: Under Review -->
{% if review_subs %}
<div class="subsection-heading">Under Review</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width: 38%;">Title</th>
      <th style="width: 18%;">Trade</th>
      <th style="width: 14%;">Type</th>
      <th style="width: 15%;">Required By</th>
      <th style="width: 15%;">Status</th>
    </tr>
  </thead>
  <tbody>
    {% for s in review_subs %}
    <tr>
      <td>{{ s.title }}</td>
      <td>{{ s.trade or "—" }}</td>
      <td>{{ s.type or "OTHER" }}</td>
      <td>{{ s.requiredBy | date_fmt }}</td>
      <td><span class="badge badge-review">{{ s.status }}</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

<!-- 2c: Approaching Deadline -->
{% if approach_subs %}
<div class="subsection-heading">Approaching Deadline</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width: 38%;">Title</th>
      <th style="width: 18%;">Trade</th>
      <th style="width: 14%;">Type</th>
      <th style="width: 15%;">Submit By</th>
      <th style="width: 15%;">Status</th>
    </tr>
  </thead>
  <tbody>
    {% for s in approach_subs %}
    <tr>
      <td>{{ s.title }}</td>
      <td>{{ s.trade or "—" }}</td>
      <td>{{ s.type or "OTHER" }}</td>
      <td>{{ (s.submitByDate or s.requiredBy) | date_fmt }}</td>
      <td><span class="badge badge-approach">{{ s.status }}</span></td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- Section 3: Open Action Items                                                -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="section-heading">3. Open Action Items</div>

{% if actionItems %}
<table class="data-table">
  <thead>
    <tr>
      <th style="width: 32%;">Description</th>
      <th style="width: 16%;">Assigned To</th>
      <th style="width: 12%;">Due</th>
      <th style="width: 10%;">Priority</th>
      <th style="width: 10%;">Status</th>
      <th style="width: 20%;">Meeting</th>
    </tr>
  </thead>
  <tbody>
    {% for item in actionItems %}
    <tr class="{% if item.priority == 'CRITICAL' %}row-critical{% elif item.priority == 'HIGH' %}row-high{% endif %}">
      <td>{{ item.description }}</td>
      <td>{{ item.assignedToName or "—" }}</td>
      <td>{{ item.dueDate | date_fmt }}</td>
      <td>
        {% if item.priority == "CRITICAL" %}
          <span class="badge badge-critical">Critical</span>
        {% elif item.priority == "HIGH" %}
          <span class="badge badge-high">High</span>
        {% elif item.priority == "MEDIUM" %}
          <span class="badge badge-medium">Medium</span>
        {% else %}
          <span class="badge badge-low">Low</span>
        {% endif %}
      </td>
      <td>
        {% if item.status == "IN_PROGRESS" %}
          <span class="badge badge-progress">In Progress</span>
        {% elif item.status == "DEFERRED" %}
          <span class="badge badge-hold">Deferred</span>
        {% else %}
          <span class="badge badge-low">Open</span>
        {% endif %}
      </td>
      <td>{{ item.meetingTitle or "—" }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
  <p class="notice">No open action items.</p>
{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- Section 4: Risk Flags (only if present)                                     -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
{% if riskFlags %}
<div class="section-heading">4. Risk Flags</div>
{% for flag in riskFlags %}
<div class="risk-block">
  <div class="risk-text">{{ flag }}</div>
</div>
{% endfor %}
{% endif %}

</body>
</html>
