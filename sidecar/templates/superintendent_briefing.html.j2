<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Superintendent Initial Assessment — {{ bid.projectName }}</title>
  <style>
    @page {
      size: letter;
      margin: 0.7in 0.75in 0.85in;
      @bottom-left {
        content: "{{ bid.projectName }} · Superintendent Initial Assessment";
        font-size: 7.5pt;
        color: #6b7280;
        font-family: Arial, Helvetica, sans-serif;
      }
      @bottom-right {
        content: "Page " counter(page) " of " counter(pages);
        font-size: 7.5pt;
        color: #6b7280;
        font-family: Arial, Helvetica, sans-serif;
      }
    }

    body {
      font-family: Arial, Helvetica, sans-serif;
      font-size: 9pt;
      color: #1f2937;
      margin: 0;
      padding: 0;
    }

    /* ── Header ──────────────────────────────────────────────────────────────── */
    .page-header {
      background-color: #0f172a;
      color: #ffffff;
      padding: 14pt 16pt;
      margin-bottom: 16pt;
    }
    .page-header table { width: 100%; border-collapse: collapse; }
    .page-header td { padding: 0; vertical-align: top; }
    .header-doc-type {
      font-size: 7.5pt;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.8pt;
      margin-bottom: 4pt;
    }
    .header-project {
      font-size: 15pt;
      font-weight: bold;
      letter-spacing: 0.2pt;
      margin-bottom: 3pt;
    }
    .header-location { font-size: 9pt; color: #cbd5e1; }
    .header-meta { text-align: right; }
    .header-meta-label {
      font-size: 7.5pt;
      color: #94a3b8;
      text-transform: uppercase;
      letter-spacing: 0.5pt;
    }
    .header-meta-value {
      font-size: 9pt;
      font-weight: bold;
      color: #f1f5f9;
      margin-top: 1pt;
      margin-bottom: 6pt;
    }
    .header-notice {
      margin-top: 10pt;
      padding: 6pt 10pt;
      background: rgba(245,158,11,0.15);
      border-left: 2pt solid #f59e0b;
      font-size: 8pt;
      color: #fde68a;
      border-radius: 2pt;
    }

    /* ── Section labels ──────────────────────────────────────────────────────── */
    .section-label {
      font-size: 7.5pt;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.8pt;
      color: #6b7280;
      border-bottom: 1pt solid #e5e7eb;
      padding-bottom: 3pt;
      margin-bottom: 7pt;
      margin-top: 16pt;
    }
    .section-label.critical { color: #b91c1c; border-color: #fecaca; }
    .section-label.warning  { color: #92400e; border-color: #fde68a; }
    .section-label.blue     { color: #1e40af; border-color: #bfdbfe; }
    .section-label.green    { color: #065f46; border-color: #6ee7b7; }

    .empty-note {
      font-size: 8pt;
      color: #9ca3af;
      font-style: italic;
      padding: 4pt 0;
    }

    /* ── Risk / flag items ───────────────────────────────────────────────────── */
    .flag-item {
      display: flex;
      align-items: flex-start;
      gap: 7pt;
      padding: 5pt 8pt;
      border-radius: 3pt;
      margin-bottom: 4pt;
    }
    .flag-risk     { background: #fef2f2; }
    .flag-spec     { background: #fff7ed; }
    .flag-tag {
      font-size: 6.5pt;
      font-weight: bold;
      text-transform: uppercase;
      padding: 1.5pt 5pt;
      border-radius: 2pt;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .tag-risk { background: #fecaca; color: #7f1d1d; }
    .tag-spec { background: #fed7aa; color: #7c2d12; }
    .flag-text { font-size: 8.5pt; color: #374151; line-height: 1.4; }
    .flag-risk .flag-text { color: #7f1d1d; }
    .flag-spec .flag-text { color: #7c2d12; }
    .flag-csi {
      font-size: 7pt;
      color: #9ca3af;
      margin-top: 1pt;
    }

    /* ── Tables (inspections, warranties, training, closeout) ───────────────── */
    .data-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 8.5pt;
    }
    .data-table th {
      background: #f9fafb;
      color: #6b7280;
      font-size: 7pt;
      text-transform: uppercase;
      letter-spacing: 0.5pt;
      padding: 4pt 6pt;
      text-align: left;
      border-top: 1pt solid #e5e7eb;
      border-bottom: 1pt solid #e5e7eb;
    }
    .data-table td {
      padding: 4pt 6pt;
      vertical-align: top;
      border-bottom: 0.5pt solid #f3f4f6;
      color: #374151;
      line-height: 1.3;
    }
    .data-table tr:last-child td { border-bottom: none; }

    .ins-type-badge {
      display: inline-block;
      font-size: 6pt;
      font-weight: bold;
      text-transform: uppercase;
      letter-spacing: 0.3pt;
      padding: 1pt 4pt;
      border-radius: 2pt;
      white-space: nowrap;
    }
    .ins-SPECIAL      { background: #fef3c7; color: #92400e; }
    .ins-AHJ          { background: #dbeafe; color: #1e40af; }
    .ins-THIRD_PARTY  { background: #f3e8ff; color: #6b21a8; }
    .ins-OWNER_WITNESS { background: #ecfdf5; color: #065f46; }
    .ins-CONTRACTOR_QC { background: #f9fafb; color: #374151; }
    .ins-OTHER        { background: #f9fafb; color: #6b7280; }

    .wty-type-badge {
      display: inline-block;
      font-size: 6pt;
      font-weight: bold;
      text-transform: uppercase;
      padding: 1pt 4pt;
      border-radius: 2pt;
      white-space: nowrap;
    }
    .wty-MANUFACTURER { background: #dbeafe; color: #1e40af; }
    .wty-INSTALLER    { background: #fef3c7; color: #92400e; }
    .wty-SYSTEM       { background: #f3e8ff; color: #6b21a8; }

    .closeout-type-badge {
      display: inline-block;
      font-size: 6pt;
      font-weight: bold;
      text-transform: uppercase;
      padding: 1pt 4pt;
      border-radius: 2pt;
      white-space: nowrap;
      background: #f3f4f6;
      color: #374151;
    }
    .closeout-COMMISSIONING { background: #dbeafe; color: #1e40af; }
    .closeout-BALANCING     { background: #ecfdf5; color: #065f46; }
    .closeout-CERTIFICATIONS { background: #fef3c7; color: #92400e; }

    .csi-ref {
      font-size: 7.5pt;
      color: #9ca3af;
    }

    /* ── Submittals ──────────────────────────────────────────────────────────── */
    .submittal-overdue  { background: #fef2f2; }
    .submittal-approaching { background: #fffbeb; }

    /* ── Schedule ────────────────────────────────────────────────────────────── */
    .sched-group-label {
      font-size: 7.5pt;
      font-weight: bold;
      color: #6b7280;
      text-transform: uppercase;
      letter-spacing: 0.4pt;
      padding: 3pt 6pt;
      background: #f9fafb;
      border-bottom: 0.5pt solid #e5e7eb;
    }
    .milestone-star { color: #f59e0b; font-weight: bold; }

    /* ── Action items ────────────────────────────────────────────────────────── */
    .priority-badge {
      display: inline-block;
      font-size: 6pt;
      font-weight: bold;
      text-transform: uppercase;
      padding: 1pt 4pt;
      border-radius: 2pt;
      white-space: nowrap;
    }
    .priority-CRITICAL { background: #fef2f2; color: #b91c1c; }
    .priority-HIGH     { background: #fff7ed; color: #c2410c; }
    .priority-MEDIUM   { background: #fefce8; color: #92400e; }
    .priority-LOW      { background: #f9fafb; color: #6b7280; }
    .superseded-note {
      font-size: 7pt;
      color: #92400e;
      text-transform: uppercase;
      letter-spacing: 0.4pt;
      margin-left: 3pt;
    }

    /* ── Footer ──────────────────────────────────────────────────────────────── */
    .doc-footer {
      margin-top: 20pt;
      padding-top: 8pt;
      border-top: 0.5pt solid #e5e7eb;
      font-size: 7.5pt;
      color: #9ca3af;
      text-align: center;
    }
  </style>
</head>
<body>

<!-- ── Header ───────────────────────────────────────────────────────────────── -->
<div class="page-header">
  <table>
    <tr>
      <td>
        <div class="header-doc-type">Superintendent · Initial Project Assessment</div>
        <div class="header-project">{{ bid.projectName }}</div>
        {% if bid.location %}
        <div class="header-location">{{ bid.location }}</div>
        {% endif %}
      </td>
      <td class="header-meta">
        <div class="header-meta-label">Reference Date</div>
        <div class="header-meta-value">{{ as_of_date_fmt }}</div>
        <div class="header-meta-label">Generated</div>
        <div style="font-size:7.5pt; color:#94a3b8; margin-top:1pt;">{{ generated_at_fmt }}</div>
      </td>
    </tr>
  </table>
  <div class="header-notice">
    This document is generated from preconstruction data — specs, schedule seed, submittals, and meeting intelligence.
    Items flagged here require active attention throughout construction. Not a substitute for the project documents.
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- §1  CONTRACT & SPEC RISK FLAGS                                             -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
{% if risk_flags or spec_flags %}
<div class="section-label critical">⚠ Contract &amp; Spec Risk Flags ({{ (risk_flags | length) + (spec_flags | length) }})</div>

{% for flag in risk_flags %}
<div class="flag-item flag-risk">
  <span class="flag-tag tag-risk">Contract</span>
  <div>
    <div class="flag-text">{{ flag }}</div>
  </div>
</div>
{% endfor %}

{% for f in spec_flags %}
<div class="flag-item flag-spec">
  <span class="flag-tag tag-spec">Spec</span>
  <div>
    <div class="flag-text">{{ f.flag }}</div>
    <div class="flag-csi">{{ f.csiNumber }} – {{ f.csiTitle }}</div>
  </div>
</div>
{% endfor %}

{% else %}
<div class="section-label critical">Contract &amp; Spec Risk Flags</div>
<p class="empty-note">No risk flags identified. Generate an intelligence brief to surface contract-level risks.</p>
{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- §2  PRE-AWARD DECISIONS                                                    -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
{% if decisions | length > 0 %}
<div class="section-label warning">Pre-Award Decisions ({{ decisions | length }})</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width:12%;">Category</th>
      <th style="width:28%;">Decision</th>
      <th style="width:24%;">Rationale</th>
      <th style="width:16%;">Source</th>
      <th style="width:10%;">Made By</th>
      <th style="width:10%;">Date</th>
    </tr>
  </thead>
  <tbody>
    {% for d in decisions %}
    {% set cat = (d.category or "OTHER") | upper %}
    <tr{% if d.status == "SUPERSEDED" %} style="opacity:0.6;"{% endif %}>
      <td>
        <span
          style="
            display:inline-block;
            padding:1pt 4pt;
            border-radius:2pt;
            font-size:6.5pt;
            font-weight:bold;
            text-transform:uppercase;
            letter-spacing:0.3pt;
            white-space:nowrap;
            {% if cat == 'SCOPE' %}background:#dbeafe;color:#1d4ed8;{% endif %}
            {% if cat == 'EXCLUSION' %}background:#fee2e2;color:#dc2626;{% endif %}
            {% if cat == 'SUBSTITUTION' %}background:#fef3c7;color:#d97706;{% endif %}
            {% if cat == 'ASSUMPTION' %}background:#f3f4f6;color:#6b7280;{% endif %}
            {% if cat == 'RISK' %}background:#ffe4e6;color:#9f1239;{% endif %}
            {% if cat == 'VE' %}background:#dcfce7;color:#15803d;{% endif %}
            {% if cat == 'DESIGN' %}background:#ede9fe;color:#7c3aed;{% endif %}
            {% if cat == 'OTHER' %}background:#f3f4f6;color:#6b7280;{% endif %}
          "
        >
          {{ cat }}
        </span>
      </td>
      <td>
        <span{% if d.status == "SUPERSEDED" %} style="font-style:italic;"{% endif %}>{{ d.decision }}</span>
        {% if d.status == "SUPERSEDED" %}
        <span class="superseded-note">(superseded)</span>
        {% endif %}
      </td>
      <td>{{ d.rationale or "—" }}</td>
      <td>{{ d.source or "—" }}</td>
      <td>{{ d.madeBy or "—" }}</td>
      <td style="white-space:nowrap;">{{ d.madeAt | date_fmt }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- §3  REQUIRED INSPECTIONS                                                   -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="section-label warning">Required Inspections{% if inspections %} ({{ inspections | length }}){% endif %}</div>

{% if inspections %}
<table class="data-table">
  <thead>
    <tr>
      <th style="width:20%;">Section</th>
      <th style="width:8%;">Type</th>
      <th style="width:28%;">Activity / What's Inspected</th>
      <th style="width:16%;">Who</th>
      <th style="width:16%;">Timing / Frequency</th>
      <th style="width:12%;">Standard</th>
    </tr>
  </thead>
  <tbody>
    {% for ins in inspections %}
    {% set ins_type = (ins.type or "OTHER") | upper %}
    <tr>
      <td><span class="csi-ref">{{ ins.csiNumber }}</span><br>{{ ins.csiTitle }}</td>
      <td><span class="ins-type-badge ins-{{ ins_type }}">{{ ins_type.replace("_"," ") }}</span></td>
      <td>{{ ins.activity or "—" }}</td>
      <td>{{ ins.who or "—" }}</td>
      <td>
        {% if ins.timing %}{{ ins.timing }}{% endif %}
        {% if ins.timing and ins.frequency %} · {% endif %}
        {% if ins.frequency %}{{ ins.frequency }}{% endif %}
        {% if not ins.timing and not ins.frequency %}—{% endif %}
      </td>
      <td>{{ ins.standard or "—" }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="empty-note">No inspection requirements extracted. Upload and analyze project specifications to populate this section.</p>
{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- §4  WARRANTY REQUIREMENTS                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<div class="section-label blue">Warranty Requirements{% if warranties %} ({{ warranties | length }}){% endif %}</div>

{% if warranties %}
<table class="data-table">
  <thead>
    <tr>
      <th style="width:20%;">Section</th>
      <th style="width:9%;">Type</th>
      <th style="width:38%;">Scope / What's Covered</th>
      <th style="width:13%;">Duration</th>
    </tr>
  </thead>
  <tbody>
    {% for w in warranties %}
    {% set wty_type = (w.type or "OTHER") | upper %}
    <tr>
      <td><span class="csi-ref">{{ w.csiNumber }}</span><br>{{ w.csiTitle }}</td>
      <td>
        {% if wty_type in ["MANUFACTURER","INSTALLER","SYSTEM"] %}
        <span class="wty-type-badge wty-{{ wty_type }}">{{ wty_type }}</span>
        {% else %}
        <span class="wty-type-badge">{{ wty_type }}</span>
        {% endif %}
      </td>
      <td>{{ w.scope or "—" }}</td>
      <td>{{ w.duration or "—" }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% else %}
<p class="empty-note">No warranty requirements extracted from specifications.</p>
{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- §5  TRAINING REQUIREMENTS                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
{% if trainings %}
<div class="section-label green">Owner &amp; Staff Training Requirements ({{ trainings | length }})</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width:20%;">Section</th>
      <th style="width:22%;">Topic</th>
      <th style="width:13%;">Audience</th>
      <th style="width:25%;">Requirement</th>
      <th style="width:10%;">Duration</th>
      <th style="width:10%;">Timing</th>
    </tr>
  </thead>
  <tbody>
    {% for t in trainings %}
    <tr>
      <td><span class="csi-ref">{{ t.csiNumber }}</span><br>{{ t.csiTitle }}</td>
      <td>{{ t.topic or "—" }}</td>
      <td>{{ (t.audience or "—") | replace("_", " ") | title }}</td>
      <td>{{ t.requirement or "—" }}</td>
      <td>{{ t.duration or "—" }}</td>
      <td>{{ t.timing or "—" }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- §6  CLOSEOUT DELIVERABLES                                                  -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
{% if closeouts %}
<div class="section-label">Closeout Deliverables Checklist ({{ closeouts | length }})</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width:12%;">Type</th>
      <th style="width:20%;">Section</th>
      <th style="width:38%;">Description</th>
      <th style="width:12%;">Quantity</th>
      <th style="width:18%;">Timing</th>
    </tr>
  </thead>
  <tbody>
    {% for c in closeouts %}
    {% set co_type = (c.type or "OTHER") | upper | replace(" ","_") %}
    <tr>
      <td>
        {% if co_type in ["COMMISSIONING","BALANCING","CERTIFICATIONS"] %}
        <span class="closeout-type-badge closeout-{{ co_type }}">{{ co_type.replace("_"," ") }}</span>
        {% else %}
        <span class="closeout-type-badge">{{ co_type.replace("_"," ") }}</span>
        {% endif %}
      </td>
      <td><span class="csi-ref">{{ c.csiNumber }}</span><br>{{ c.csiTitle }}</td>
      <td>{{ c.description or "—" }}</td>
      <td>{{ c.quantity or "—" }}</td>
      <td>{{ c.timing or "—" }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- §7  SUBMITTALS REQUIRING ATTENTION                                         -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
{% set urgent_subs = submittals | selectattr("isOverdue") | list %}
{% set approaching_subs = submittals | selectattr("isApproaching") | list %}
{% if urgent_subs or approaching_subs %}
<div class="section-label warning">Submittals Requiring Attention ({{ (urgent_subs | length) + (approaching_subs | length) }})</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width:40%;">Submittal</th>
      <th style="width:15%;">Trade</th>
      <th style="width:12%;">Type</th>
      <th style="width:13%;">Submit By</th>
      <th style="width:13%;">Required By</th>
      <th style="width:7%;">Status</th>
    </tr>
  </thead>
  <tbody>
    {% for s in urgent_subs %}
    <tr class="submittal-overdue">
      <td>{{ s.title }}</td>
      <td>{{ s.trade or "—" }}</td>
      <td>{{ s.type | replace("_", " ") | title }}</td>
      <td>{{ s.submitByDate | date_fmt }}</td>
      <td>{{ s.requiredBy | date_fmt }}</td>
      <td style="color:#b91c1c; font-weight:bold; font-size:7.5pt;">OVERDUE</td>
    </tr>
    {% endfor %}
    {% for s in approaching_subs %}
    <tr class="submittal-approaching">
      <td>{{ s.title }}</td>
      <td>{{ s.trade or "—" }}</td>
      <td>{{ s.type | replace("_", " ") | title }}</td>
      <td>{{ s.submitByDate | date_fmt }}</td>
      <td>{{ s.requiredBy | date_fmt }}</td>
      <td style="color:#92400e; font-size:7.5pt;">UPCOMING</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- §8  SCHEDULE                                                               -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
{% if schedule.overdue or schedule.thisWeek or schedule.lookahead %}
<div class="section-label">Schedule — {{ lookahead_days }}-Day Lookahead from {{ as_of_date_fmt }}</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width:36%;">Activity</th>
      <th style="width:14%;">Trade</th>
      <th style="width:12%;">Start</th>
      <th style="width:12%;">Finish</th>
      <th style="width:10%;">Complete</th>
      <th style="width:16%;">Status</th>
    </tr>
  </thead>
  <tbody>
    {% if schedule.overdue %}
    <tr><td colspan="6" class="sched-group-label">Overdue ({{ schedule.overdue | length }})</td></tr>
    {% for a in schedule.overdue %}
    <tr style="background:#fef2f2;">
      <td>{% if a.isMilestone %}<span class="milestone-star">★ </span>{% endif %}{{ a.name }}</td>
      <td>{{ a.trade or "—" }}</td>
      <td>{{ a.startDate  | date_fmt }}</td>
      <td>{{ a.finishDate | date_fmt }}</td>
      <td>{{ a.percentComplete }}%</td>
      <td style="color:#b91c1c; font-weight:bold; font-size:7.5pt;">OVERDUE</td>
    </tr>
    {% endfor %}
    {% endif %}

    {% if schedule.thisWeek %}
    <tr><td colspan="6" class="sched-group-label">This Week ({{ schedule.thisWeek | length }})</td></tr>
    {% for a in schedule.thisWeek %}
    <tr>
      <td>{% if a.isMilestone %}<span class="milestone-star">★ </span>{% endif %}{{ a.name }}</td>
      <td>{{ a.trade or "—" }}</td>
      <td>{{ a.startDate  | date_fmt }}</td>
      <td>{{ a.finishDate | date_fmt }}</td>
      <td>{{ a.percentComplete }}%</td>
      <td>{{ a.status | replace("_", " ") | title }}</td>
    </tr>
    {% endfor %}
    {% endif %}

    {% if schedule.lookahead %}
    <tr><td colspan="6" class="sched-group-label">{{ lookahead_days }}-Day Lookahead ({{ schedule.lookahead | length }})</td></tr>
    {% for a in schedule.lookahead %}
    <tr>
      <td>{% if a.isMilestone %}<span class="milestone-star">★ </span>{% endif %}{{ a.name }}</td>
      <td>{{ a.trade or "—" }}</td>
      <td>{{ a.startDate  | date_fmt }}</td>
      <td>{{ a.finishDate | date_fmt }}</td>
      <td>{{ a.percentComplete }}%</td>
      <td>{{ a.status | replace("_", " ") | title }}</td>
    </tr>
    {% endfor %}
    {% endif %}
  </tbody>
</table>
{% endif %}


<!-- ═══════════════════════════════════════════════════════════════════════════ -->
<!-- §9  OPEN PRECONSTRUCTION COMMITMENTS                                       -->
<!-- ═══════════════════════════════════════════════════════════════════════════ -->
{% if actionItems %}
<div class="section-label">Open Preconstruction Commitments ({{ actionItems | length }})</div>
<table class="data-table">
  <thead>
    <tr>
      <th style="width:42%;">Item</th>
      <th style="width:18%;">Assigned To</th>
      <th style="width:11%;">Due</th>
      <th style="width:9%;">Priority</th>
      <th style="width:20%;">From Meeting</th>
    </tr>
  </thead>
  <tbody>
    {% for item in actionItems %}
    <tr>
      <td>{{ item.description }}</td>
      <td>{{ item.assignedToName or "—" }}</td>
      <td style="white-space:nowrap;">{{ item.dueDate | date_fmt }}</td>
      <td>
        <span class="priority-badge priority-{{ item.priority }}">{{ item.priority }}</span>
      </td>
      <td style="font-size:8pt; color:#6b7280;">{{ item.meetingTitle or "—" }}</td>
    </tr>
    {% endfor %}
  </tbody>
</table>
{% endif %}

<div class="doc-footer">
  Generated by NeuroGlitch Construction Intelligence · {{ generated_at_fmt }} ·
  Data sourced from preconstruction spec analysis, schedule seed, and meeting intelligence.
</div>

</body>
</html>
