# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Transcription ─────────────────────────────────────────────────────────────
# AssemblyAI — cloud fallback when GPU worker is unavailable
ASSEMBLYAI_API_KEY=

# ── GPU Worker (WhisperX via Tailscale) ───────────────────────────────────────
# Tailscale IP of the GPU PC running whisperx_server.py
# Example: http://100.x.x.x:8002
WHISPERX_URL=
# Must match WHISPERX_API_KEY set when installing the GPU worker service
WHISPERX_API_KEY=

# ── Sidecar auth ──────────────────────────────────────────────────────────────
# Shared secret for X-API-Key header. Leave blank in dev (allows all requests).
# Must match SIDECAR_API_KEY in .env.local
SIDECAR_API_KEY=
