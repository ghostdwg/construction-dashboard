# ── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth (Auth.js v5) ─────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
AUTH_SECRET=
# Set to "true" for solo dev mode (no login required)
AUTH_DISABLED=false
# Generate: openssl rand -hex 32  (required to save secrets in settings UI)
SETTINGS_ENCRYPTION_KEY=

# ── Python sidecar ────────────────────────────────────────────────────────────
SIDECAR_URL=http://127.0.0.1:8001
# Must match SIDECAR_API_KEY in sidecar/.env (leave blank in dev)
SIDECAR_API_KEY=

# ── App URL (used for webhooks + email callbacks) ─────────────────────────────
# Self-hosted: your Tailscale IP or local domain
# Example: http://100.x.x.x:3000
APP_URL=http://localhost:3000

# ── Webhook callback token (sidecar → app) ────────────────────────────────────
# Generate: openssl rand -hex 32
SIDECAR_CALLBACK_TOKEN=

# ── Feature flags ─────────────────────────────────────────────────────────────
BRIEF_STUB_MODE=false
GAP_STUB_MODE=false
ADDENDUM_STUB_MODE=false
