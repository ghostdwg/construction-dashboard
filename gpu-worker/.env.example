# ── GPU Worker environment ────────────────────────────────────────────────────
# HuggingFace token for pyannote speaker diarization model download.
# Get one at: https://huggingface.co/settings/tokens
# Also accept model gates at:
#   https://huggingface.co/pyannote/speaker-diarization-3.1
#   https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_...

# Shared secret — must match WHISPERX_API_KEY in sidecar/.env
WHISPERX_API_KEY=

# Whisper model size: base / medium / large-v2  (large-v2 recommended for accuracy)
WHISPERX_MODEL=large-v2

# Port the server listens on (default 8002)
PORT=8002
