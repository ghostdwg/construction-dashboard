{
  "name": "construction-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:sidecar": "cd sidecar && .venv\\Scripts\\uvicorn.exe main:app --host 127.0.0.1 --port 8001 --reload",
    "dev:all": "npx concurrently \"npm run dev\" \"npm run dev:sidecar\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@auth/prisma-adapter": "^2.11.1",
    "@libsql/client": "^0.17.2",
    "@prisma/adapter-libsql": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@react-email/components": "^1.0.12",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "bcryptjs": "^3.0.3",
    "exceljs": "^4.4.0",
    "immer": "^11.1.4",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.4",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.7",
    "pdfjs-dist": "^5.6.205",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hotkeys-hook": "^5.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "xmlbuilder2": "^4.0.3",
    "zod": "^4.4.2",
    "zustand": "^5.0.12"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/ui": "^4.1.5",
    "concurrently": "^9",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^4.1.5"
  }
}
