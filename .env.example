# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path (relative to project root).
# For local dev, this default works as-is.
# For production, switch to a Turso/libSQL remote URL:
#   DATABASE_URL="libsql://your-db.turso.io?authToken=your-token"
DATABASE_URL="file:./dev.db"

# ── Anthropic API ─────────────────────────────────────────────────────────────
# Required for AI features: leveling question drafting (Module 6c),
# AI Review prompt enhancement (Module 15 — not yet built).
# Without this key the app runs normally but AI features fall back to templates.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=""
