generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // URL is configured in prisma.config.ts (Prisma 7 — not in schema.prisma)
  // To switch to PostgreSQL: see docs/architecture/POSTGRES_MIGRATION.md
}

// ── Auth Wall (Auth.js v5 + Prisma Adapter) ─────────────────────────────────
//
// Standard Auth.js models + custom fields (hashedPassword, role).
// Session strategy is JWT so the Session model is only needed if we later
// switch to database sessions (e.g. for OAuth providers).

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           String    @default("estimator") // admin | estimator | pm
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trade {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  costCode    String?
  csiCode     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  bidTrades        BidTrade[]
  subTrades        SubcontractorTrade[]
  scopeItems       ScopeItem[]
  tradeAssignments ScopeTradeAssignment[]
  preferredSubs    PreferredSub[]
  levelingRows     LevelingRow[]
  specSections         SpecSection[]  @relation("SpecSectionTrade")
  matchedSpecSections  SpecSection[]  @relation("MatchedSpecSection")
  drawingSheets        DrawingSheet[] @relation("DrawingSheetTrade")
  matchedDrawingSheets DrawingSheet[] @relation("MatchedDrawingSheet")
}

model Bid {
  id          Int       @id @default(autoincrement())
  projectName String
  location    String?
  description String?
  scope       String    @default("")
  status        String    @default("draft")
  workflowType  String    @default("BID")   // "BID" | "PROJECT"
  projectType ProjectType @default(PRIVATE)
  dueDate             DateTime?
  complianceChecklist String?
  createdById         String?   // Auth Wall — nullable, backfill to user 1 when multi-tenant
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Module INT1 — Job Intake (Wing 1 project context capture)
  // String fields validated in API layer rather than enum (SQLite-friendly).
  // Valid deliveryMethod: HARD_BID, DESIGN_BUILD, CM_AT_RISK, NEGOTIATED
  // Valid ownerType:      PUBLIC_ENTITY, PRIVATE_OWNER, DEVELOPER, INSTITUTIONAL
  deliveryMethod     String?
  ownerType          String?
  buildingType       String?
  approxSqft         Int?
  stories            Int?
  ldAmountPerDay     Float?
  ldCapAmount        Float?
  occupiedSpace      Boolean   @default(false)
  phasingRequired    Boolean   @default(false)
  siteConstraints    String?
  estimatorNotes     String?
  scopeBoundaryNotes String?
  veInterest         Boolean   @default(false)
  dbeGoalPercent     Float?

  // Module H4 — Schedule Seed
  constructionStartDate DateTime?
  projectDurationDays   Int?

  // Module H6 — Budget Creation
  // JSON: Array<{ label: string; costCode: string; amount: number }>
  budgetGcLines         String?

  // Tier F F2 — Procore REST API
  procoreProjectId      String?

  bidTrades        BidTrade[]
  selections       BidInviteSelection[]
  exportBatches    ExportBatch[]
  scopeItems       ScopeItem[]
  aiExportBatches  AiExportBatch[]
  gapFindings      AiGapFinding[]
  outreachLogs     OutreachLog[]
  estimateUploads     EstimateUpload[]
  levelingSession     LevelingSession?
  generatedQuestions  GeneratedQuestion[]
  specBooks           SpecBook[]
  drawingUploads      DrawingUpload[]
  addendums           AddendumUpload[]
  intelligenceBrief   BidIntelligenceBrief?
  submission          BidSubmission?
  buyoutItems         BuyoutItem[]
  submittalItems              SubmittalItem[]
  submittalPackages           SubmittalPackage[]
  distributionTemplates       SubmittalDistributionTemplate[]
  projectContacts             ProjectContact[]
  scheduleActivities  ScheduleActivity[]
  schedules           Schedule[]
  meetings            Meeting[]
  meetingActionItems  MeetingActionItem[]
  procorePushes       ProcorePush[]
  rfiItems            RfiItem[]
  backgroundJobs      BackgroundJob[]
  marketLeads         MarketLead[]
}

model BidSubmission {
  id                   Int       @id @default(autoincrement())
  bidId                Int       @unique
  submittedAt          DateTime  @default(now())
  submittedBy          String?
  ourBidAmount         Float?
  notes                String?

  // Frozen snapshots (JSON)
  briefSnapshot        String?
  questionSnapshot     String?
  complianceSnapshot   String?
  spreadSnapshot       String?
  gateSnapshot         String?
  intelligenceSnapshot String?

  // Outcome fields (D2)
  outcome              String?
  outcomeAt            DateTime?
  winningBidAmount     Float?
  ourRank              Int?
  totalBidders         Int?
  lostReason           String?
  lostReasonNote       String?
  lessonsLearned       String?
  outcomeNotes         String?

  bid Bid @relation(fields: [bidId], references: [id])
}

model BidTrade {
  id               Int       @id @default(autoincrement())
  bidId            Int
  tradeId          Int
  scopeNotes       String?
  tier             String    @default("TIER2")
  leadTimeDays     Int?
  rfqSentAt        DateTime?
  quotesReceivedAt DateTime?
  rfqNotes         String?

  bid                Bid                 @relation(fields: [bidId], references: [id])
  trade              Trade               @relation(fields: [tradeId], references: [id])
  buyoutItem             BuyoutItem?
  submittalItems         SubmittalItem[]
  submittalPackages      SubmittalPackage[]
  distributionTemplates  SubmittalDistributionTemplate[]
  scheduleActivities     ScheduleActivity[]

  @@unique([bidId, tradeId])
}

// Module H2 — Buyout Tracker
// One BuyoutItem per BidTrade. Auto-created on first read of the buyout
// endpoint, then updated via PATCH as the estimator works through buyout.
// contractStatus values (validated in API, not enum for SQLite friendliness):
//   PENDING | LOI_SENT | CONTRACT_SENT | CONTRACT_SIGNED | PO_ISSUED | ACTIVE | CLOSED
model BuyoutItem {
  id                Int       @id @default(autoincrement())
  bidId             Int
  bidTradeId        Int       @unique
  subcontractorId   Int?

  // Commitment
  committedAmount   Float?
  originalBidAmount Float?

  // Contract lifecycle
  contractStatus    String    @default("PENDING")
  loiSentAt         DateTime?
  contractSentAt    DateTime?
  contractSignedAt  DateTime?
  poNumber          String?
  poIssuedAt        DateTime?

  // Financial tracking
  changeOrderAmount Float?    @default(0)
  paidToDate        Float?    @default(0)
  retainagePercent  Float?    @default(5)

  notes             String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  bid           Bid            @relation(fields: [bidId], references: [id], onDelete: Cascade)
  bidTrade      BidTrade       @relation(fields: [bidTradeId], references: [id], onDelete: Cascade)
  subcontractor Subcontractor? @relation(fields: [subcontractorId], references: [id])

  @@index([bidId])
  @@index([subcontractorId])
}

model Subcontractor {
  id        Int      @id @default(autoincrement())
  company   String
  office    String?
  status    String   @default("active")
  notes     String?
  isUnion   Boolean  @default(false)
  isMWBE    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tier            String  @default("new")
  projectTypes    String  @default("")
  region          String?
  lastBidDate     DateTime?
  internalNotes   String?
  doNotUse        Boolean  @default(false)
  doNotUseReason  String?

  // INTERNAL ONLY — never expose in AI prompts, recipient exports, or sub-facing artifacts
  isPreferred     Boolean @default(false)
  // External system reference (Procore vendor id) — used for re-import dedup
  procoreVendorId String? @unique

  contacts           Contact[]
  subTrades          SubcontractorTrade[]
  selections         BidInviteSelection[]
  outreachLogs       OutreachLog[]
  preferredForTrades PreferredSub[]
  estimateUploads    EstimateUpload[]
  buyoutItems        BuyoutItem[]
  submittalItems     SubmittalItem[]
}

model SubcontractorTrade {
  id              Int @id @default(autoincrement())
  subcontractorId Int
  tradeId         Int

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  trade         Trade         @relation(fields: [tradeId], references: [id])

  @@unique([subcontractorId, tradeId])
}

model Contact {
  id              Int      @id @default(autoincrement())
  subcontractorId Int
  name            String
  email           String?
  phone           String?
  title           String?
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  outreachLogs  OutreachLog[]
}

model BidInviteSelection {
  id              Int      @id @default(autoincrement())
  bidId           Int
  subcontractorId Int
  tradeId         Int?
  notes           String?
  createdAt       DateTime @default(now())

  rfqStatus          String    @default("no_response")
  invitedAt          DateTime?
  estimateReceivedAt DateTime?
  estimateFileName   String?
  followUpCount      Int       @default(0)
  selectionNotes     String?

  bid           Bid           @relation(fields: [bidId], references: [id])
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
}

model PreferredSub {
  id              Int      @id @default(autoincrement())
  tradeId         Int
  subcontractorId Int
  createdAt       DateTime @default(now())

  trade         Trade         @relation(fields: [tradeId], references: [id])
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])

  @@unique([tradeId, subcontractorId])
}

model ScopeItem {
  id          Int      @id @default(autoincrement())
  bidId       Int
  tradeId     Int?
  description String
  inclusion   Boolean  @default(true)
  specSection String?
  drawingRef  String?
  notes       String?
  riskFlag    Boolean  @default(false)
  restricted  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bid              Bid                    @relation(fields: [bidId], references: [id])
  trade            Trade?                 @relation(fields: [tradeId], references: [id])
  tradeAssignments ScopeTradeAssignment[]
}

model ScopeTradeAssignment {
  id          Int      @id @default(autoincrement())
  scopeItemId Int
  tradeId     Int
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  scopeItem ScopeItem @relation(fields: [scopeItemId], references: [id])
  trade     Trade     @relation(fields: [tradeId], references: [id])

  @@unique([scopeItemId, tradeId])
}

model ExportBatch {
  id          Int      @id @default(autoincrement())
  bidId       Int
  exportedAt  DateTime @default(now())
  rowCount    Int
  fileName    String

  bid Bid @relation(fields: [bidId], references: [id])
}

model AiExportBatch {
  id              Int       @id @default(autoincrement())
  bidId           Int
  exportedBy      String?
  approvedBy      String?
  approvedAt      DateTime?
  restrictedCount Int       @default(0)
  status          String    @default("complete")
  createdAt       DateTime  @default(now())

  bid         Bid            @relation(fields: [bidId], references: [id])
  gapFindings AiGapFinding[]
}

model AiGapFinding {
  id              Int      @id @default(autoincrement())
  bidId           Int
  aiExportBatchId Int?
  tradeName       String?
  title           String?
  findingText     String
  sourceRef       String?
  confidence      String?
  severity        String?
  sourceDocument  String?
  status          String   @default("pending_review")
  reviewNotes     String?
  createdAt       DateTime @default(now())

  bid                Bid            @relation(fields: [bidId], references: [id])
  aiExportBatch      AiExportBatch? @relation(fields: [aiExportBatchId], references: [id])
  generatedQuestions GeneratedQuestion[]
}

model GeneratedQuestion {
  id             Int         @id @default(autoincrement())
  rfiNumber      Int?
  gapFindingId   Int?
  bidId          Int?
  levelingRowId  Int?
  tradeName      String?
  questionText   String
  isInternal     Boolean     @default(true)
  status         RfiStatus   @default(OPEN)
  priority       RfiPriority @default(MEDIUM)
  approvedAt     DateTime?
  sentAt         DateTime?
  responseText   String?
  respondedAt    DateTime?
  respondedBy    String?
  impactFlag     Boolean     @default(false)
  impactNote     String?
  sourceRef      String?
  dueDate        DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  gapFinding   AiGapFinding? @relation(fields: [gapFindingId], references: [id])
  bid          Bid?          @relation(fields: [bidId], references: [id])
  levelingRow  LevelingRow?  @relation(fields: [levelingRowId], references: [id])
  outreachLogs OutreachLog[]
}

model OutreachLog {
  id              Int       @id @default(autoincrement())
  bidId           Int
  subcontractorId Int?
  contactId       Int?
  questionId      Int?
  channel         String?
  status          String    @default("exported")
  sentAt          DateTime?
  respondedAt     DateTime?
  responseNotes   String?
  followUpDue     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Module H8 — plain-string recipient for notifications where the FK
  // target isn't a sub Contact (e.g. ProjectContact rows for internal notifications).
  recipientEmail String?

  // Email delivery tracking (Module RFQ1)
  // deliveryStatus values (validated in API): QUEUED, SENT, DELIVERED, OPENED, BOUNCED, FAILED
  emailMessageId String?
  deliveryStatus String?
  openedAt       DateTime?
  bouncedAt      DateTime?
  bounceReason   String?

  bid           Bid                @relation(fields: [bidId], references: [id])
  subcontractor Subcontractor?     @relation(fields: [subcontractorId], references: [id])
  contact       Contact?           @relation(fields: [contactId], references: [id])
  question      GeneratedQuestion? @relation(fields: [questionId], references: [id])

  @@index([emailMessageId])
}

enum ProjectType {
  PUBLIC
  PRIVATE
  NEGOTIATED
}

enum RfiStatus {
  OPEN
  SENT
  ANSWERED
  CLOSED
  NO_RESPONSE
}

enum RfiPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ParseStatus {
  pending
  processing
  complete
  failed
}

model EstimateUpload {
  id                  Int         @id @default(autoincrement())
  bidId               Int
  subcontractorId     Int
  fileName            String
  fileType            String
  fileSize            Int
  rawFilePath         String
  scopeLines          String      @default("")
  pricingData         String      @default("")
  parseStatus         ParseStatus @default(pending)
  parseError          String?
  sanitizedText       String?
  sanitizationStatus  String?
  redactionCount      Int?
  flaggedLines        String?
  subToken            String?
  approvedForAi       Boolean     @default(false)
  parsedTotal         Float?
  parsedLineCount     Int?
  uploadedAt          DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  bid           Bid           @relation(fields: [bidId], references: [id])
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  levelingRows  LevelingRow[]

  @@unique([bidId, subcontractorId])
}

model LevelingSession {
  id        Int      @id @default(autoincrement())
  bidId     Int      @unique
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bid  Bid           @relation(fields: [bidId], references: [id])
  rows LevelingRow[]
}

model LevelingRow {
  id               Int      @id @default(autoincrement())
  sessionId        Int
  estimateUploadId Int
  tradeId          Int?
  division         String   @default("")
  scopeText        String
  scopeHash        String
  status           String   @default("unreviewed")
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session        LevelingSession     @relation(fields: [sessionId], references: [id])
  estimateUpload EstimateUpload      @relation(fields: [estimateUploadId], references: [id])
  trade          Trade?              @relation(fields: [tradeId], references: [id])
  questions      GeneratedQuestion[]

  @@unique([estimateUploadId, scopeHash])
}

model SpecBook {
  id         Int      @id @default(autoincrement())
  bidId      Int
  fileName   String
  filePath   String
  uploadedAt DateTime @default(now())
  status     String   @default("processing")

  bid      Bid           @relation(fields: [bidId], references: [id])
  sections SpecSection[]
}

model SpecSection {
  id                 Int      @id @default(autoincrement())
  csiCanonicalTitle  String?          // enriched from CsiMasterformat on split
  specBookId     Int
  csiNumber      String
  csiTitle       String
  rawText        String   @default("")
  tradeId        Int?
  matchedTradeId Int?
  source         String?
  covered        Boolean  @default(false)
  createdAt      DateTime @default(now())

  // Phase 5A: AI extraction results (JSON blob from Claude analysis)
  // Contains: submittals, warranties, training, testing, closeout, products, performance
  aiExtractions  String?

  // Phase 5A: per-section PDF split (Procore-style)
  // Each section extracted as its own PDF file for download/preview/AI analysis
  pdfPath        String?   // Server path to the split PDF
  pdfFileName    String?   // Display filename (e.g., "03_30_00_cast_in_place_concrete.pdf")
  pageStart      Int?      // 1-indexed start page in original spec book
  pageEnd        Int?      // 1-indexed end page
  pageCount      Int?

  specBook       SpecBook        @relation(fields: [specBookId], references: [id], onDelete: Cascade)
  trade          Trade?          @relation("SpecSectionTrade", fields: [tradeId], references: [id])
  matchedTrade   Trade?          @relation("MatchedSpecSection", fields: [matchedTradeId], references: [id])
  submittalItems SubmittalItem[]
}

// Drawing uploads support two modes:
//   FULLSET  — one PDF containing all disciplines (legacy behavior)
//   Per-discipline — one PDF per discipline (ARCH, CIVIL, STRUCT, MECH, ELEC, PLUMB, INTERIOR, FP, GENERAL)
// Multiple uploads per bid are allowed. Re-uploading the same discipline replaces it.
model DrawingUpload {
  id         Int      @id @default(autoincrement())
  bidId      Int
  fileName   String
  filePath   String
  uploadedAt DateTime @default(now())
  status     String   @default("processing")

  // Discipline tag: FULLSET | GENERAL | CIVIL | ARCH | STRUCT | MECH | ELEC | PLUMB | INTERIOR | FP
  // Validated in API, not enum for SQLite friendliness.
  discipline String   @default("FULLSET")

  // AI analysis fields
  analysisStatus      String?   // "processing" | "ready" | "error"
  analysisTier        Int?      // 1 | 2 | 3
  analysisModel       String?   // "haiku" | "sonnet" | "opus"
  analysisJson        String?   // JSON result blob
  analysisGeneratedAt DateTime?

  bid    Bid            @relation(fields: [bidId], references: [id])
  sheets DrawingSheet[]

  @@index([bidId, discipline])
}

model AddendumUpload {
  id               Int       @id @default(autoincrement())
  bidId            Int
  addendumNumber   Int
  addendumDate     DateTime?
  fileName         String
  uploadedAt       DateTime  @default(now())
  status           String    @default("processing")
  extractedText    String?
  deltaJson        String?
  deltaGeneratedAt DateTime?
  summary          String?

  bid Bid @relation(fields: [bidId], references: [id])
}

model BidIntelligenceBrief {
  id                   Int      @id @default(autoincrement())
  bidId                Int      @unique
  generatedAt          DateTime @default(now())
  status               String   @default("generating")
  whatIsThisJob        String?
  howItGetsBuilt       String?
  riskFlags            String?
  assumptionsToResolve String?
  addendumSummary      String?
  addendumCount        Int      @default(0)
  isStale              Boolean  @default(false)
  sourceContext        String?
  triggeredBy          String?
  addendumDeltas       String?

  bid Bid @relation(fields: [bidId], references: [id])
}

model DrawingSheet {
  id              Int      @id @default(autoincrement())
  drawingUploadId Int
  sheetNumber     String
  sheetTitle      String?
  discipline      String?
  matchedTradeId  Int?
  tradeId         Int?
  createdAt       DateTime @default(now())

  drawingUpload DrawingUpload @relation(fields: [drawingUploadId], references: [id], onDelete: Cascade)
  trade         Trade?        @relation("DrawingSheetTrade", fields: [tradeId], references: [id])
  matchedTrade  Trade?        @relation("MatchedDrawingSheet", fields: [matchedTradeId], references: [id])
}

// Module H3 — Submittal Register
// One SubmittalItem per required submittal. Seeded from SpecSection.rawText
// via regex extraction, then manually managed through the lifecycle.
//
// Valid type values (validated in API, not enum for SQLite friendliness):
//   PRODUCT_DATA | SHOP_DRAWING | SAMPLE | MOCKUP | WARRANTY | O_AND_M | LEED | CERT | OTHER
// Valid status values:
//   PENDING | REQUESTED | RECEIVED | UNDER_REVIEW | APPROVED | APPROVED_AS_NOTED | REJECTED | RESUBMIT
// Phase 5G-3.5 — Submittal Package (Procore-compatible container)
//
// Groups SubmittalItems — maps 1:1 to Procore's "Submittal Package" field on
// CSV import/export. Typically one package per trade (Concrete, Masonry,
// Electrical). Auto-created when AI generator runs; user can rename/merge.
model SubmittalPackage {
  id            Int      @id @default(autoincrement())
  bidId         Int
  packageNumber String            // "PKG-01", "PKG-02" — unique per bid
  name          String            // "Concrete", "Electrical", "HVAC Closeout"
  status        String   @default("DRAFT")  // DRAFT | OPEN | CLOSED

  // Optional 1:1 link to a bid trade (most packages mirror trades)
  bidTradeId    Int?

  // Package-level defaults (items in package inherit unless overridden)
  responsibleContractor   String?
  submittalManager        String?
  defaultReviewers        String?   // JSON array: ["GC PM", "Architect"]
  defaultDistribution     String?   // JSON array: ["Owner Rep", "Inspector"]

  // Orchestrator — timing defaults inherited by items lacking individual overrides
  defaultLeadTimeDays       Int?
  defaultReviewBufferDays   Int?
  defaultResubmitBufferDays Int?

  // Orchestrator — schedule linkage + risk + export readiness
  linkedActivityId  String?
  riskStatus        String   @default("NONE")   // NONE | AT_RISK | BLOCKED
  readyForExport    Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bid             Bid                  @relation(fields: [bidId], references: [id], onDelete: Cascade)
  bidTrade        BidTrade?            @relation(fields: [bidTradeId], references: [id])
  linkedActivity  ScheduleActivityV2?  @relation(fields: [linkedActivityId], references: [id], onDelete: SetNull)
  items           SubmittalItem[]

  @@unique([bidId, packageNumber])
  @@index([bidId])
  @@index([linkedActivityId])
}

// Module CSI1 — Canonical CSI MasterFormat 2020 reference
//
// Seeded from prisma/seed/data/CSI_MasterFormat_2020.xlsx (Level 3 only).
// Used by the spec splitter and AI pipeline to validate/reconcile parsed
// section titles against the official MasterFormat naming.
model CsiMasterformat {
  id             Int    @id @default(autoincrement())
  csiNumber      String @unique    // "03 30 00"
  canonicalTitle String              // "Cast-in-Place Concrete"
  division       String              // "03"

  @@index([division])
}

model SubmittalItem {
  id               Int       @id @default(autoincrement())
  bidId            Int
  bidTradeId       Int?
  specSectionId    Int?
  packageId        Int?      // Phase 5G-3.5 — optional FK to SubmittalPackage

  submittalNumber  String?
  title            String
  description      String?
  type             String    @default("OTHER")

  // Provenance — "manual" | "regex_seed" | "ai_extraction"
  source           String    @default("manual")

  // Lifecycle
  status           String    @default("PENDING")
  requiredBy       DateTime?
  requestedAt      DateTime?
  receivedAt       DateTime?
  reviewedAt       DateTime?
  approvedAt       DateTime?
  reviewRound      Int       @default(1)

  // Attribution
  responsibleSubId Int?
  reviewer         String?

  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // GWX-006 — Audit attribution: which BackgroundJob created this item.
  // Null for manually-created items. Set by generateSubmittalsFromAiAnalysis
  // when called from the sidecar webhook callback.
  sourceJobId      String?

  // Phase 5G-2 — Schedule-tied due dates
  // Backward math: submitByDate = linkedActivity.startDate - leadTimeDays - reviewBufferDays - resubmitBufferDays
  linkedActivityId    String?   // FK to ScheduleActivityV2
  leadTimeDays        Int       @default(0)    // mfr delivery lead time (working days)
  reviewBufferDays    Int       @default(21)   // A/E review window per AIA A201 §4.2.7
  resubmitBufferDays  Int       @default(7)    // one resubmission cycle buffer
  requiredOnSiteDate  DateTime?               // derived: linkedActivity.startDate - leadTimeDays
  submitByDate        DateTime?               // derived: requiredOnSiteDate - reviewBuffer - resubmitBuffer

  bid            Bid               @relation(fields: [bidId], references: [id], onDelete: Cascade)
  bidTrade       BidTrade?         @relation(fields: [bidTradeId], references: [id])
  specSection    SpecSection?      @relation(fields: [specSectionId], references: [id])
  responsibleSub Subcontractor?    @relation(fields: [responsibleSubId], references: [id])
  package        SubmittalPackage? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  linkedActivity ScheduleActivityV2? @relation(fields: [linkedActivityId], references: [id], onDelete: SetNull)
  sourceJob      BackgroundJob?    @relation(fields: [sourceJobId], references: [id], onDelete: SetNull)

  @@index([bidId])
  @@index([specSectionId])
  @@index([status])
  @@index([packageId])
  @@index([linkedActivityId])
  @@index([sourceJobId])
}

// Phase 5G-3 — Per-trade submittal routing template
//
// One row per (bid, trade). Stores the default contractor, submittal manager,
// reviewer chain, and distribution list for submittals belonging to that trade.
// Auto-applied to packages when AI generation runs; user edits via the
// Routing panel on the Submittals tab. Override per submittal is via the
// item's own reviewer field or the package's responsibleContractor field.
model SubmittalDistributionTemplate {
  id                    Int       @id @default(autoincrement())
  bidId                 Int
  bidTradeId            Int?      // null = bid-wide fallback

  responsibleContractor String?   // default sub/vendor responsible for submittals
  submittalManager      String?   // GC role/person who manages the package
  reviewers             String    @default("[]")   // JSON: ["Architect", "MEP Eng"]
  distribution          String    @default("[]")   // JSON: ["Owner Rep", "Inspector"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bid      Bid       @relation(fields: [bidId], references: [id], onDelete: Cascade)
  bidTrade BidTrade? @relation(fields: [bidTradeId], references: [id], onDelete: Cascade)

  @@unique([bidId, bidTradeId])
  @@index([bidId])
}

// Module H1 — Project Contacts (owner / architect / engineer / internal team)
//
// Replaces the deferred contacts placeholder in the H1 Handoff Packet. One row
// per contact, parented to a Bid. Manageable on the Overview and Handoff tabs.
//
// Valid role values (validated in API, not enum for SQLite friendliness):
//   OWNER | OWNER_REP | ARCHITECT | ENGINEER |
//   INTERNAL_PM | INTERNAL_ESTIMATOR | INTERNAL_SUPER | OTHER
model ProjectContact {
  id        Int      @id @default(autoincrement())
  bidId     Int

  role      String   @default("OTHER")

  name      String
  company   String?
  title     String?
  email     String?
  phone     String?
  notes     String?

  // Within a role, primary contacts sort first. Multiple primaries allowed.
  isPrimary Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bid                 Bid                  @relation(fields: [bidId], references: [id], onDelete: Cascade)
  meetingParticipants MeetingParticipant[]

  @@index([bidId])
  @@index([bidId, role])
}

// Module H4 — Schedule Seed
// One ScheduleActivity per BidTrade (plus 2 milestones). Seeded from the
// bid's trade list in canonical CSI order, then manually refined. MS Project
// CSV export is the primary delivery.
//
// Valid kind values (validated in API, not enum for SQLite friendliness):
//   CONSTRUCTION | MILESTONE
//
// predecessorIds is a comma-separated list of activityId strings (Primavera
// style — e.g. "A1010,A1020"). Only Finish-to-Start is supported in v1.
model ScheduleActivity {
  id             Int       @id @default(autoincrement())
  bidId          Int
  bidTradeId     Int?

  activityId     String    // "A1010" style
  name           String
  kind           String    @default("CONSTRUCTION")
  sequence       Int       @default(0)

  durationDays   Int       @default(5)
  startDate      DateTime?
  finishDate     DateTime?
  predecessorIds String?

  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bid      Bid       @relation(fields: [bidId], references: [id], onDelete: Cascade)
  bidTrade BidTrade? @relation(fields: [bidTradeId], references: [id])

  @@index([bidId])
  @@index([bidId, sequence])
}

// ── Phase 5C — Schedule V2 ───────────────────────────────────────────────────
//
// New data model for the full-featured schedule editor. The old ScheduleActivity
// (H4) is preserved until migration is complete (Phase 11+).
//
// weatherMode: BUFFER | CONTRACTUAL | TRACK_ONLY
// activeLayers: JSON array of active layer keys, e.g. ["weather_a201","procurement"]
//
model Schedule {
  id              String    @id @default(cuid())
  bidId           Int
  bid             Bid       @relation(fields: [bidId], references: [id], onDelete: Cascade)
  name            String    @default("Baseline Schedule")
  startDate       DateTime
  isBaseline      Boolean   @default(false)
  baselinedAt     DateTime?
  weatherMode     String    @default("BUFFER")
  weatherStation  String?
  weatherBaseline String?   // JSON: { stationId, annualDays, monthlyDays[] }
  activeLayers    String    @default("[]") // JSON: string[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  activities ScheduleActivityV2[]
  versions   ScheduleVersion[]

  @@index([bidId])
}

// Valid status values: not_started | in_progress | complete | on_hold
// Valid weatherCode: WS-0 through WS-5 (impact tiers defined in Phase 5C docs)
// outlineLevel: 1=phase summary, 2=category summary, 3=task
model ScheduleActivityV2 {
  id                 String    @id @default(cuid())
  scheduleId         String
  schedule           Schedule  @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  activityCode       String
  wbsId              String    @default("")
  outlineLevel       Int       @default(3)
  sortOrder          Int       @default(0)
  name               String
  duration           Int       @default(5)
  isSummary          Boolean   @default(false)
  isMilestone        Boolean   @default(false)
  csiCode            String?
  trade              String?
  weatherCode        String    @default("WS-0")
  requiresInspection Boolean   @default(false)
  notes              String    @default("")
  aiGenerated        Boolean   @default(false)
  aiConfidence       String?
  layerSource        String?
  status             String    @default("not_started")
  percentComplete    Float     @default(0)
  actualStart        DateTime?
  actualFinish       DateTime?
  remainingDuration  Int?
  delayReason        String?
  startDate          DateTime?
  finishDate         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  predecessors       ScheduleDependency[] @relation("SuccessorActivity")
  successors         ScheduleDependency[] @relation("PredecessorActivity")
  submittals         SubmittalItem[]
  submittalPackages  SubmittalPackage[]

  @@index([scheduleId])
  @@index([scheduleId, sortOrder])
}

// type: FS (Finish-to-Start) | SS (Start-to-Start) | FF (Finish-to-Finish) | SF (Start-to-Finish)
// lag: positive = lag days, negative = lead days (working days)
model ScheduleDependency {
  id            String @id @default(cuid())
  predecessorId String
  successorId   String
  type          String @default("FS")
  lag           Int    @default(0)

  predecessor ScheduleActivityV2 @relation("PredecessorActivity", fields: [predecessorId], references: [id], onDelete: Cascade)
  successor   ScheduleActivityV2 @relation("SuccessorActivity",   fields: [successorId],   references: [id], onDelete: Cascade)

  @@unique([predecessorId, successorId, type])
  @@index([successorId])
}

// Versioned snapshots: baseline, what-if, issued-for-review, etc.
// snapshot is a JSON string of { activities, dependencies } at save time.
model ScheduleVersion {
  id          String   @id @default(cuid())
  scheduleId  String
  schedule    Schedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  versionName String
  snapshot    String   // JSON
  createdAt   DateTime @default(now())

  @@index([scheduleId])
}

// Per-AI-call max_tokens overrides. If a row exists for a callKey, that value
// overrides the hardcoded default in lib/services/ai/aiTokenConfig.ts.
model AiTokenConfig {
  id        Int      @id @default(autoincrement())
  callKey   String   @unique
  maxTokens Int
  updatedAt DateTime @updatedAt
}

// Module SET1 — App Settings (key/value)
//
// Hot-applied settings stored in DB. Reads are cached in-process and the
// cache is invalidated on every write. Designed for credentials + config that
// the user can change from the /settings UI without restarting the dev server.
//
// Conventions:
// - Secret values (keys marked secret:true in SETTING_DEFINITIONS) are encrypted
//   at rest using AES-256-GCM when SETTINGS_ENCRYPTION_KEY is set in the env.
//   Stored format: "enc:v1:<iv_hex>:<auth_tag_hex>:<ciphertext_hex>"
// - Without SETTINGS_ENCRYPTION_KEY, secrets are stored plaintext (same as before).
// - Service code reads via getSetting(key) — decryption is transparent.
// - The UI masks secret values to last-4 display.
model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Module SET1 — AI Usage Log
//
// One row per Anthropic API call. Powers the Usage subsection on the AI
// settings card and the cost estimator's calibration data.
//
// callKey aligns with AI_CALL_DEFINITIONS in aiTokenConfig.ts.
model AiUsageLog {
  id              Int       @id @default(autoincrement())
  callKey         String
  model           String
  inputTokens     Int
  outputTokens   Int
  costUsd         Float
  bidId           Int?
  status          String    @default("ok") // "ok" | "error"
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([callKey])
  @@index([createdAt])
  @@index([bidId])
}

// ── Phase 5D — Meeting Intelligence Pipeline ────────────────────────────────
//
// Three-model stack: Meeting → MeetingParticipant → MeetingActionItem
//
// meetingType values (validated in API):
//   GENERAL | OAC | SUBCONTRACTOR | PRECONSTRUCTION | SAFETY | KICKOFF
//
// status values (FSM):
//   PENDING → UPLOADING → TRANSCRIBING → ANALYZING → READY | FAILED
//
// transcriptionSource values:
//   ASSEMBLYAI | WHISPERX | MANUAL

model Meeting {
  id                  Int       @id @default(autoincrement())
  bidId               Int
  title               String
  meetingDate         DateTime
  meetingType         String    @default("GENERAL")
  location            String?
  status              String    @default("PENDING")
  audioFileName       String?
  durationSeconds     Int?
  transcriptionSource String?
  transcriptionJobId  String?   // AssemblyAI transcript_id or WhisperX job id
  rawTranscript       String?   // full JSON blob from transcription service
  transcript          String?   // speaker-labeled formatted text for display + Claude
  summary             String?   // Claude-generated 2-3 sentence overview (§3)
  keyDecisions        String    @default("[]")   // JSON: string[]                       (§4)
  risks               String    @default("[]")   // JSON: { description, severity }[]    (legacy)
  followUpItems       String    @default("[]")   // JSON: string[]                       (legacy)
  // ── 8-section analysis output fields ──────────────────────────────────────
  openIssues          String    @default("[]")   // JSON: MeetingOpenIssue[]             (§6)
  redFlags            String    @default("[]")   // JSON: MeetingRedFlag[]               (§7)
  reviewStatus        String    @default("DRAFT") // "DRAFT" | "IN_REVIEW" | "PUBLISHED"
  publishedAt         DateTime?
  analysisVersion     Int       @default(0)      // increments on each re-analysis
  uploadedAt          DateTime?
  analyzedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  bid          Bid                  @relation(fields: [bidId], references: [id], onDelete: Cascade)
  actionItems  MeetingActionItem[]
  participants MeetingParticipant[]

  @@index([bidId])
  @@index([bidId, meetingDate])
}

// Persistent speaker roster per meeting. Speaker labels from diarization
// (SPEAKER_A, SPEAKER_B) are resolved to real names by the user post-upload.
// Optionally linked to a ProjectContact for cross-meeting context.
model MeetingParticipant {
  id               Int      @id @default(autoincrement())
  meetingId        Int
  name             String
  role             String?
  company          String?
  speakerLabel     String?  // "SPEAKER_A" / "ROOM_SPK_1" from diarization
  speakerType      String?  // "REMOTE" | "IN_ROOM" | "UNKNOWN"
  confidence       Float?   // 0.0–1.0 identity confidence from AI inference
  isGcTeam         Boolean  @default(false) // GC team member — drives §8 bold + filter
  projectContactId Int?

  meeting        Meeting         @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  projectContact ProjectContact? @relation(fields: [projectContactId], references: [id], onDelete: SetNull)
  actionItems    MeetingActionItem[]

  @@index([meetingId])
}

// Action items extracted from meeting transcripts by Claude (and manually added).
//
// priority values: LOW | MEDIUM | HIGH | CRITICAL
// status values:   OPEN | IN_PROGRESS | CLOSED | DEFERRED
model MeetingActionItem {
  id             Int       @id @default(autoincrement())
  bidId          Int
  meetingId      Int?      // null for manually created tasks
  source         String    @default("meeting")  // "meeting" | "manual"
  description    String
  assignedToId   Int?      // FK to MeetingParticipant
  assignedToName String?   // denormalized — survives participant edits
  dueDate        DateTime?
  priority       String    @default("MEDIUM")
  status         String    @default("OPEN")
  sourceText     String?   // paraphrased evidence excerpt from transcript
  isGcTask       Boolean   @default(false) // GC team task — populates §8
  carriedFromDate String?  // ISO date of meeting where this first appeared
  closedAt       DateTime?
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bid        Bid                  @relation(fields: [bidId], references: [id], onDelete: Cascade)
  meeting    Meeting?             @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  assignedTo MeetingParticipant?  @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  @@index([bidId])
  @@index([meetingId])
  @@index([status])
  @@index([source])
}

// ── Tier F F2 — Procore REST API push history ───────────────────────────────
//
// One row per push operation. Tracks created/updated/skipped counts and any
// partial errors. Multiple rows per bid+pushType accumulate as history;
// the UI shows the most recent row per type.
//
// pushType values: "vendors" | "contacts" | "submittals" | "budget"
//
// errors is a JSON array of short error strings (one per failed item, max 50).

model ProcorePush {
  id        Int      @id @default(autoincrement())
  bidId     Int
  pushType  String
  pushedAt  DateTime @default(now())
  created   Int      @default(0)
  updated   Int      @default(0)
  skipped   Int      @default(0)
  errors    String?

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([bidId, pushType])
}

// ── Tier F F3 — RFI items pulled from Procore ───────────────────────────────
//
// One row per RFI in the linked Procore project. procoreRfiId is the Procore
// numeric ID; the unique index prevents duplicate pulls on re-sync.
// syncedAt tracks when this record was last pulled from Procore.

model RfiItem {
  id            Int       @id @default(autoincrement())
  bidId         Int
  procoreRfiId  Int?
  number        String
  title         String
  question      String?
  answer        String?
  status        String    @default("open")
  priority      String?
  assigneeName  String?
  dueDate       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  syncedAt      DateTime?

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@unique([bidId, procoreRfiId])
  @@index([bidId])
}

// ── GWX-003 — Durable Background Job Record ─────────────────────────────────
//
// One row per background/async work unit. Replaces process-memory job state as
// the authoritative source of truth for overnight work and long-running analysis.
//
// jobType values: "spec_analysis" | "drawing_analysis" | "meeting_transcription"
//
// status FSM: queued → running → complete | failed | cancelled
//
// externalJobId — the sidecar's in-memory job_id for active polling while the
//   sidecar is alive. Stored here so it survives the browser being closed.
//
// triggerSource: "user" | "automation" | "webhook"
model BackgroundJob {
  id            String    @id @default(cuid())
  jobType       String
  status        String    @default("queued")

  // Context — which bid/document this job is about
  bidId         Int?
  relatedId     String?   // specBookId, drawingUploadId, meetingId as string

  // Sidecar reference — external job_id for progress polling while sidecar lives
  externalJobId String?

  // Input metadata (lightweight summary, not full payload)
  inputSummary  String?   // e.g. "32 sections, tier 2"

  // Result metadata (set on complete)
  resultSummary String?   // e.g. "32 sections saved, $1.42"
  artifactType  String?   // "spec_sections" | "drawing_sheets" etc.

  // Error detail (set on failed)
  errorMessage  String?

  // Lifecycle timestamps
  createdAt     DateTime  @default(now())
  startedAt     DateTime?
  completedAt   DateTime?

  // Operational metadata
  retryCount    Int       @default(0)
  triggerSource String    @default("user")

  // GWX-005.1 — Atomic duplicate prevention
  // Active (queued/running) jobs hold activeSlot=1; terminal jobs clear it to null.
  // The @@unique below enforces at most one active job per (bidId, jobType) at the
  // DB level. SQLite treats NULLs as distinct in unique indexes, so terminal rows
  // (activeSlot=null) never conflict with each other.
  activeSlot    Int?      @default(1)

  bid            Bid?           @relation(fields: [bidId], references: [id], onDelete: SetNull)
  submittalItems SubmittalItem[]

  @@unique([bidId, jobType, activeSlot])
  @@index([bidId])
  @@index([jobType, status])
  @@index([status, createdAt])
  @@index([externalJobId])
}

// ── Tier F F3 — Procore webhook event log ───────────────────────────────────
//
// Stores incoming Procore webhook events. Unprocessed events (processed=false)
// are handled by the webhook receiver after storing. The payload column holds
// the raw JSON body for replay/debugging.

model ProcoreWebhookEvent {
  id           Int      @id @default(autoincrement())
  receivedAt   DateTime @default(now())
  eventType    String
  resourceType String
  resourceId   Int?
  projectId    Int?
  companyId    Int?
  payload      String
  processed    Boolean  @default(false)
  processedAt  DateTime?
  error        String?

  @@index([resourceType, resourceId])
  @@index([processed])
}

// ── Phase 2 — Market Intelligence Desk ──────────────────────────────────────
//
// Three-model stack: MarketLead ← MarketSignal, RelationshipEdge (standalone)
//
// MarketLead: a detected or manually-entered opportunity worth tracking.
//   leadType: PERMIT | MEETING_MINUTE | PLAN_ROOM | LAND_ACQUISITION | BROKER | RELATIONSHIP | MANUAL
//   status:   NEW | REVIEWING | QUALIFIED | PURSUING | ARCHIVED | DISMISSED
//   confidence: LOW | MEDIUM | HIGH
model MarketLead {
  id              String    @id @default(cuid())
  title           String
  leadType        String    @default("MANUAL")
  source          String?   // "beeline" | "city_hall" | "blue_book" | "county_records" | "manual"
  sourceUrl       String?
  status          String    @default("NEW")
  confidence      String    @default("MEDIUM")
  aiScore         Int?      // 0–100 overall signal strength
  location        String?
  jurisdiction    String?   // city or county
  projectType     String?   // building use / type
  estimatedValue  Float?
  rawText         String?   // original scraped content
  aiSummary       String?   // Claude-generated one-paragraph brief
  aiInsights      String?   // JSON: { strengths: string[], risks: string[], angle: string }
  detectedAt      DateTime  @default(now())
  promotedToBidId Int?      // set when user promotes this lead to an active pursuit
  promotedAt      DateTime?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  signals     MarketSignal[]
  promotedBid Bid?           @relation(fields: [promotedToBidId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([leadType])
  @@index([detectedAt])
  @@index([promotedToBidId])
}

// MarketSignal: a raw piece of market evidence (permit filing, plan room posting,
// meeting minute entry, land transaction, broker listing). Many signals can
// reference one lead, or exist unassigned (leadId = null).
//
// signalType: PERMIT | MEETING_MINUTE | PLAN_ROOM_JOB | PLAN_ROOM_VIEW |
//             LAND_ACQUISITION | BROKER_LISTING | ARCHITECT_PROJECT | MANUAL
model MarketSignal {
  id               String    @id @default(cuid())
  leadId           String?
  signalType       String
  source           String?
  sourceUrl        String?
  sourceDate       DateTime?
  headline         String
  rawText          String?
  metadata         String?   // JSON: source-specific fields (permit no., parcel id, etc.)
  aiRelevanceScore Int?      // 0–100
  createdAt        DateTime  @default(now())

  lead MarketLead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([signalType])
  @@index([createdAt])
}

// RelationshipEdge: architect↔GC, owner↔GC, developer↔GC associations derived
// from past projects, permit history, and market scrapes.
//
// fromType / toType: GC | ARCHITECT | OWNER | DEVELOPER | ENGINEER | BROKER
// relationshipType:  DESIGNED | BUILT | PARTNERED | COMPETING | OWNED
model RelationshipEdge {
  id               String    @id @default(cuid())
  fromType         String
  fromName         String
  toType           String
  toName           String
  relationshipType String
  projectName      String?
  projectValue     Float?
  projectYear      Int?
  location         String?
  source           String?
  sourceUrl        String?
  confidence       String    @default("MEDIUM")
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([fromName])
  @@index([toName])
  @@index([relationshipType])
}
