generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ── Auth Wall (Auth.js v5 + Prisma Adapter) ─────────────────────────────────
//
// Standard Auth.js models + custom fields (hashedPassword, role).
// Session strategy is JWT so the Session model is only needed if we later
// switch to database sessions (e.g. for OAuth providers).

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String    @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  role           String    @default("estimator") // admin | estimator | pm
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Trade {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  costCode    String?
  csiCode     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  bidTrades        BidTrade[]
  subTrades        SubcontractorTrade[]
  scopeItems       ScopeItem[]
  tradeAssignments ScopeTradeAssignment[]
  preferredSubs    PreferredSub[]
  levelingRows     LevelingRow[]
  specSections         SpecSection[]  @relation("SpecSectionTrade")
  matchedSpecSections  SpecSection[]  @relation("MatchedSpecSection")
  drawingSheets        DrawingSheet[] @relation("DrawingSheetTrade")
  matchedDrawingSheets DrawingSheet[] @relation("MatchedDrawingSheet")
}

model Bid {
  id          Int       @id @default(autoincrement())
  projectName String
  location    String?
  description String?
  scope       String    @default("")
  status      String    @default("draft")
  projectType ProjectType @default(PRIVATE)
  dueDate             DateTime?
  complianceChecklist String?
  createdById         String?   // Auth Wall — nullable, backfill to user 1 when multi-tenant
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Module INT1 — Job Intake (Wing 1 project context capture)
  // String fields validated in API layer rather than enum (SQLite-friendly).
  // Valid deliveryMethod: HARD_BID, DESIGN_BUILD, CM_AT_RISK, NEGOTIATED
  // Valid ownerType:      PUBLIC_ENTITY, PRIVATE_OWNER, DEVELOPER, INSTITUTIONAL
  deliveryMethod     String?
  ownerType          String?
  buildingType       String?
  approxSqft         Int?
  stories            Int?
  ldAmountPerDay     Float?
  ldCapAmount        Float?
  occupiedSpace      Boolean   @default(false)
  phasingRequired    Boolean   @default(false)
  siteConstraints    String?
  estimatorNotes     String?
  scopeBoundaryNotes String?
  veInterest         Boolean   @default(false)
  dbeGoalPercent     Float?

  // Module H4 — Schedule Seed
  constructionStartDate DateTime?
  projectDurationDays   Int?

  // Module H6 — Budget Creation
  // JSON: Array<{ label: string; costCode: string; amount: number }>
  budgetGcLines         String?

  bidTrades        BidTrade[]
  selections       BidInviteSelection[]
  exportBatches    ExportBatch[]
  scopeItems       ScopeItem[]
  aiExportBatches  AiExportBatch[]
  gapFindings      AiGapFinding[]
  outreachLogs     OutreachLog[]
  estimateUploads     EstimateUpload[]
  levelingSession     LevelingSession?
  generatedQuestions  GeneratedQuestion[]
  specBooks           SpecBook[]
  drawingUploads      DrawingUpload[]
  addendums           AddendumUpload[]
  intelligenceBrief   BidIntelligenceBrief?
  submission          BidSubmission?
  buyoutItems         BuyoutItem[]
  submittalItems      SubmittalItem[]
  projectContacts     ProjectContact[]
  scheduleActivities  ScheduleActivity[]
}

model BidSubmission {
  id                   Int       @id @default(autoincrement())
  bidId                Int       @unique
  submittedAt          DateTime  @default(now())
  submittedBy          String?
  ourBidAmount         Float?
  notes                String?

  // Frozen snapshots (JSON)
  briefSnapshot        String?
  questionSnapshot     String?
  complianceSnapshot   String?
  spreadSnapshot       String?
  gateSnapshot         String?
  intelligenceSnapshot String?

  // Outcome fields (D2)
  outcome              String?
  outcomeAt            DateTime?
  winningBidAmount     Float?
  ourRank              Int?
  totalBidders         Int?
  lostReason           String?
  lostReasonNote       String?
  lessonsLearned       String?
  outcomeNotes         String?

  bid Bid @relation(fields: [bidId], references: [id])
}

model BidTrade {
  id               Int       @id @default(autoincrement())
  bidId            Int
  tradeId          Int
  scopeNotes       String?
  tier             String    @default("TIER2")
  leadTimeDays     Int?
  rfqSentAt        DateTime?
  quotesReceivedAt DateTime?
  rfqNotes         String?

  bid                Bid                 @relation(fields: [bidId], references: [id])
  trade              Trade               @relation(fields: [tradeId], references: [id])
  buyoutItem         BuyoutItem?
  submittalItems     SubmittalItem[]
  scheduleActivities ScheduleActivity[]

  @@unique([bidId, tradeId])
}

// Module H2 — Buyout Tracker
// One BuyoutItem per BidTrade. Auto-created on first read of the buyout
// endpoint, then updated via PATCH as the estimator works through buyout.
// contractStatus values (validated in API, not enum for SQLite friendliness):
//   PENDING | LOI_SENT | CONTRACT_SENT | CONTRACT_SIGNED | PO_ISSUED | ACTIVE | CLOSED
model BuyoutItem {
  id                Int       @id @default(autoincrement())
  bidId             Int
  bidTradeId        Int       @unique
  subcontractorId   Int?

  // Commitment
  committedAmount   Float?
  originalBidAmount Float?

  // Contract lifecycle
  contractStatus    String    @default("PENDING")
  loiSentAt         DateTime?
  contractSentAt    DateTime?
  contractSignedAt  DateTime?
  poNumber          String?
  poIssuedAt        DateTime?

  // Financial tracking
  changeOrderAmount Float?    @default(0)
  paidToDate        Float?    @default(0)
  retainagePercent  Float?    @default(5)

  notes             String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  bid           Bid            @relation(fields: [bidId], references: [id], onDelete: Cascade)
  bidTrade      BidTrade       @relation(fields: [bidTradeId], references: [id], onDelete: Cascade)
  subcontractor Subcontractor? @relation(fields: [subcontractorId], references: [id])

  @@index([bidId])
  @@index([subcontractorId])
}

model Subcontractor {
  id        Int      @id @default(autoincrement())
  company   String
  office    String?
  status    String   @default("active")
  notes     String?
  isUnion   Boolean  @default(false)
  isMWBE    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tier            String  @default("new")
  projectTypes    String  @default("")
  region          String?
  lastBidDate     DateTime?
  internalNotes   String?
  doNotUse        Boolean  @default(false)
  doNotUseReason  String?

  // INTERNAL ONLY — never expose in AI prompts, recipient exports, or sub-facing artifacts
  isPreferred     Boolean @default(false)
  // External system reference (Procore vendor id) — used for re-import dedup
  procoreVendorId String? @unique

  contacts           Contact[]
  subTrades          SubcontractorTrade[]
  selections         BidInviteSelection[]
  outreachLogs       OutreachLog[]
  preferredForTrades PreferredSub[]
  estimateUploads    EstimateUpload[]
  buyoutItems        BuyoutItem[]
  submittalItems     SubmittalItem[]
}

model SubcontractorTrade {
  id              Int @id @default(autoincrement())
  subcontractorId Int
  tradeId         Int

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  trade         Trade         @relation(fields: [tradeId], references: [id])

  @@unique([subcontractorId, tradeId])
}

model Contact {
  id              Int      @id @default(autoincrement())
  subcontractorId Int
  name            String
  email           String?
  phone           String?
  title           String?
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  outreachLogs  OutreachLog[]
}

model BidInviteSelection {
  id              Int      @id @default(autoincrement())
  bidId           Int
  subcontractorId Int
  tradeId         Int?
  notes           String?
  createdAt       DateTime @default(now())

  rfqStatus          String    @default("no_response")
  invitedAt          DateTime?
  estimateReceivedAt DateTime?
  estimateFileName   String?
  followUpCount      Int       @default(0)
  selectionNotes     String?

  bid           Bid           @relation(fields: [bidId], references: [id])
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
}

model PreferredSub {
  id              Int      @id @default(autoincrement())
  tradeId         Int
  subcontractorId Int
  createdAt       DateTime @default(now())

  trade         Trade         @relation(fields: [tradeId], references: [id])
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])

  @@unique([tradeId, subcontractorId])
}

model ScopeItem {
  id          Int      @id @default(autoincrement())
  bidId       Int
  tradeId     Int?
  description String
  inclusion   Boolean  @default(true)
  specSection String?
  drawingRef  String?
  notes       String?
  riskFlag    Boolean  @default(false)
  restricted  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bid              Bid                    @relation(fields: [bidId], references: [id])
  trade            Trade?                 @relation(fields: [tradeId], references: [id])
  tradeAssignments ScopeTradeAssignment[]
}

model ScopeTradeAssignment {
  id          Int      @id @default(autoincrement())
  scopeItemId Int
  tradeId     Int
  isPrimary   Boolean  @default(false)
  notes       String?
  createdAt   DateTime @default(now())

  scopeItem ScopeItem @relation(fields: [scopeItemId], references: [id])
  trade     Trade     @relation(fields: [tradeId], references: [id])

  @@unique([scopeItemId, tradeId])
}

model ExportBatch {
  id          Int      @id @default(autoincrement())
  bidId       Int
  exportedAt  DateTime @default(now())
  rowCount    Int
  fileName    String

  bid Bid @relation(fields: [bidId], references: [id])
}

model AiExportBatch {
  id              Int       @id @default(autoincrement())
  bidId           Int
  exportedBy      String?
  approvedBy      String?
  approvedAt      DateTime?
  restrictedCount Int       @default(0)
  status          String    @default("complete")
  createdAt       DateTime  @default(now())

  bid         Bid            @relation(fields: [bidId], references: [id])
  gapFindings AiGapFinding[]
}

model AiGapFinding {
  id              Int      @id @default(autoincrement())
  bidId           Int
  aiExportBatchId Int?
  tradeName       String?
  title           String?
  findingText     String
  sourceRef       String?
  confidence      String?
  severity        String?
  sourceDocument  String?
  status          String   @default("pending_review")
  reviewNotes     String?
  createdAt       DateTime @default(now())

  bid                Bid            @relation(fields: [bidId], references: [id])
  aiExportBatch      AiExportBatch? @relation(fields: [aiExportBatchId], references: [id])
  generatedQuestions GeneratedQuestion[]
}

model GeneratedQuestion {
  id             Int         @id @default(autoincrement())
  rfiNumber      Int?
  gapFindingId   Int?
  bidId          Int?
  levelingRowId  Int?
  tradeName      String?
  questionText   String
  isInternal     Boolean     @default(true)
  status         RfiStatus   @default(OPEN)
  priority       RfiPriority @default(MEDIUM)
  approvedAt     DateTime?
  sentAt         DateTime?
  responseText   String?
  respondedAt    DateTime?
  respondedBy    String?
  impactFlag     Boolean     @default(false)
  impactNote     String?
  sourceRef      String?
  dueDate        DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  gapFinding   AiGapFinding? @relation(fields: [gapFindingId], references: [id])
  bid          Bid?          @relation(fields: [bidId], references: [id])
  levelingRow  LevelingRow?  @relation(fields: [levelingRowId], references: [id])
  outreachLogs OutreachLog[]
}

model OutreachLog {
  id              Int       @id @default(autoincrement())
  bidId           Int
  subcontractorId Int?
  contactId       Int?
  questionId      Int?
  channel         String?
  status          String    @default("exported")
  sentAt          DateTime?
  respondedAt     DateTime?
  responseNotes   String?
  followUpDue     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Module H8 — plain-string recipient for notifications where the FK
  // target isn't a sub Contact (e.g. ProjectContact rows for internal notifications).
  recipientEmail String?

  // Email delivery tracking (Module RFQ1)
  // deliveryStatus values (validated in API): QUEUED, SENT, DELIVERED, OPENED, BOUNCED, FAILED
  emailMessageId String?
  deliveryStatus String?
  openedAt       DateTime?
  bouncedAt      DateTime?
  bounceReason   String?

  bid           Bid                @relation(fields: [bidId], references: [id])
  subcontractor Subcontractor?     @relation(fields: [subcontractorId], references: [id])
  contact       Contact?           @relation(fields: [contactId], references: [id])
  question      GeneratedQuestion? @relation(fields: [questionId], references: [id])

  @@index([emailMessageId])
}

enum ProjectType {
  PUBLIC
  PRIVATE
  NEGOTIATED
}

enum RfiStatus {
  OPEN
  SENT
  ANSWERED
  CLOSED
  NO_RESPONSE
}

enum RfiPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW
}

enum ParseStatus {
  pending
  processing
  complete
  failed
}

model EstimateUpload {
  id                  Int         @id @default(autoincrement())
  bidId               Int
  subcontractorId     Int
  fileName            String
  fileType            String
  fileSize            Int
  rawFilePath         String
  scopeLines          String      @default("")
  pricingData         String      @default("")
  parseStatus         ParseStatus @default(pending)
  parseError          String?
  sanitizedText       String?
  sanitizationStatus  String?
  redactionCount      Int?
  flaggedLines        String?
  subToken            String?
  approvedForAi       Boolean     @default(false)
  parsedTotal         Float?
  parsedLineCount     Int?
  uploadedAt          DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  bid           Bid           @relation(fields: [bidId], references: [id])
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  levelingRows  LevelingRow[]

  @@unique([bidId, subcontractorId])
}

model LevelingSession {
  id        Int      @id @default(autoincrement())
  bidId     Int      @unique
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bid  Bid           @relation(fields: [bidId], references: [id])
  rows LevelingRow[]
}

model LevelingRow {
  id               Int      @id @default(autoincrement())
  sessionId        Int
  estimateUploadId Int
  tradeId          Int?
  division         String   @default("")
  scopeText        String
  scopeHash        String
  status           String   @default("unreviewed")
  note             String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  session        LevelingSession     @relation(fields: [sessionId], references: [id])
  estimateUpload EstimateUpload      @relation(fields: [estimateUploadId], references: [id])
  trade          Trade?              @relation(fields: [tradeId], references: [id])
  questions      GeneratedQuestion[]

  @@unique([estimateUploadId, scopeHash])
}

model SpecBook {
  id         Int      @id @default(autoincrement())
  bidId      Int
  fileName   String
  filePath   String
  uploadedAt DateTime @default(now())
  status     String   @default("processing")

  bid      Bid           @relation(fields: [bidId], references: [id])
  sections SpecSection[]
}

model SpecSection {
  id             Int      @id @default(autoincrement())
  specBookId     Int
  csiNumber      String
  csiTitle       String
  rawText        String   @default("")
  tradeId        Int?
  matchedTradeId Int?
  source         String?
  covered        Boolean  @default(false)
  createdAt      DateTime @default(now())

  // Phase 5A: AI extraction results (JSON blob from Claude analysis)
  // Contains: submittals, warranties, training, testing, closeout, products, performance
  aiExtractions  String?

  specBook       SpecBook        @relation(fields: [specBookId], references: [id], onDelete: Cascade)
  trade          Trade?          @relation("SpecSectionTrade", fields: [tradeId], references: [id])
  matchedTrade   Trade?          @relation("MatchedSpecSection", fields: [matchedTradeId], references: [id])
  submittalItems SubmittalItem[]
}

// Drawing uploads support two modes:
//   FULLSET  — one PDF containing all disciplines (legacy behavior)
//   Per-discipline — one PDF per discipline (ARCH, CIVIL, STRUCT, MECH, ELEC, PLUMB, INTERIOR, FP, GENERAL)
// Multiple uploads per bid are allowed. Re-uploading the same discipline replaces it.
model DrawingUpload {
  id         Int      @id @default(autoincrement())
  bidId      Int
  fileName   String
  filePath   String
  uploadedAt DateTime @default(now())
  status     String   @default("processing")

  // Discipline tag: FULLSET | GENERAL | CIVIL | ARCH | STRUCT | MECH | ELEC | PLUMB | INTERIOR | FP
  // Validated in API, not enum for SQLite friendliness.
  discipline String   @default("FULLSET")

  bid    Bid            @relation(fields: [bidId], references: [id])
  sheets DrawingSheet[]

  @@index([bidId, discipline])
}

model AddendumUpload {
  id               Int       @id @default(autoincrement())
  bidId            Int
  addendumNumber   Int
  addendumDate     DateTime?
  fileName         String
  uploadedAt       DateTime  @default(now())
  status           String    @default("processing")
  extractedText    String?
  deltaJson        String?
  deltaGeneratedAt DateTime?
  summary          String?

  bid Bid @relation(fields: [bidId], references: [id])
}

model BidIntelligenceBrief {
  id                   Int      @id @default(autoincrement())
  bidId                Int      @unique
  generatedAt          DateTime @default(now())
  status               String   @default("generating")
  whatIsThisJob        String?
  howItGetsBuilt       String?
  riskFlags            String?
  assumptionsToResolve String?
  addendumSummary      String?
  addendumCount        Int      @default(0)
  isStale              Boolean  @default(false)
  sourceContext        String?
  triggeredBy          String?
  addendumDeltas       String?

  bid Bid @relation(fields: [bidId], references: [id])
}

model DrawingSheet {
  id              Int      @id @default(autoincrement())
  drawingUploadId Int
  sheetNumber     String
  sheetTitle      String?
  discipline      String?
  matchedTradeId  Int?
  tradeId         Int?
  createdAt       DateTime @default(now())

  drawingUpload DrawingUpload @relation(fields: [drawingUploadId], references: [id], onDelete: Cascade)
  trade         Trade?        @relation("DrawingSheetTrade", fields: [tradeId], references: [id])
  matchedTrade  Trade?        @relation("MatchedDrawingSheet", fields: [matchedTradeId], references: [id])
}

// Module H3 — Submittal Register
// One SubmittalItem per required submittal. Seeded from SpecSection.rawText
// via regex extraction, then manually managed through the lifecycle.
//
// Valid type values (validated in API, not enum for SQLite friendliness):
//   PRODUCT_DATA | SHOP_DRAWING | SAMPLE | MOCKUP | WARRANTY | O_AND_M | LEED | CERT | OTHER
// Valid status values:
//   PENDING | REQUESTED | RECEIVED | UNDER_REVIEW | APPROVED | APPROVED_AS_NOTED | REJECTED | RESUBMIT
model SubmittalItem {
  id               Int       @id @default(autoincrement())
  bidId            Int
  bidTradeId       Int?
  specSectionId    Int?

  submittalNumber  String?
  title            String
  description      String?
  type             String    @default("OTHER")

  // Lifecycle
  status           String    @default("PENDING")
  requiredBy       DateTime?
  requestedAt      DateTime?
  receivedAt       DateTime?
  reviewedAt       DateTime?
  approvedAt       DateTime?

  // Attribution
  responsibleSubId Int?
  reviewer         String?

  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  bid            Bid            @relation(fields: [bidId], references: [id], onDelete: Cascade)
  bidTrade       BidTrade?      @relation(fields: [bidTradeId], references: [id])
  specSection    SpecSection?   @relation(fields: [specSectionId], references: [id])
  responsibleSub Subcontractor? @relation(fields: [responsibleSubId], references: [id])

  @@index([bidId])
  @@index([specSectionId])
  @@index([status])
}

// Module H1 — Project Contacts (owner / architect / engineer / internal team)
//
// Replaces the deferred contacts placeholder in the H1 Handoff Packet. One row
// per contact, parented to a Bid. Manageable on the Overview and Handoff tabs.
//
// Valid role values (validated in API, not enum for SQLite friendliness):
//   OWNER | OWNER_REP | ARCHITECT | ENGINEER |
//   INTERNAL_PM | INTERNAL_ESTIMATOR | INTERNAL_SUPER | OTHER
model ProjectContact {
  id        Int      @id @default(autoincrement())
  bidId     Int

  role      String   @default("OTHER")

  name      String
  company   String?
  title     String?
  email     String?
  phone     String?
  notes     String?

  // Within a role, primary contacts sort first. Multiple primaries allowed.
  isPrimary Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bid Bid @relation(fields: [bidId], references: [id], onDelete: Cascade)

  @@index([bidId])
  @@index([bidId, role])
}

// Module H4 — Schedule Seed
// One ScheduleActivity per BidTrade (plus 2 milestones). Seeded from the
// bid's trade list in canonical CSI order, then manually refined. MS Project
// CSV export is the primary delivery.
//
// Valid kind values (validated in API, not enum for SQLite friendliness):
//   CONSTRUCTION | MILESTONE
//
// predecessorIds is a comma-separated list of activityId strings (Primavera
// style — e.g. "A1010,A1020"). Only Finish-to-Start is supported in v1.
model ScheduleActivity {
  id             Int       @id @default(autoincrement())
  bidId          Int
  bidTradeId     Int?

  activityId     String    // "A1010" style
  name           String
  kind           String    @default("CONSTRUCTION")
  sequence       Int       @default(0)

  durationDays   Int       @default(5)
  startDate      DateTime?
  finishDate     DateTime?
  predecessorIds String?

  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  bid      Bid       @relation(fields: [bidId], references: [id], onDelete: Cascade)
  bidTrade BidTrade? @relation(fields: [bidTradeId], references: [id])

  @@index([bidId])
  @@index([bidId, sequence])
}

// Per-AI-call max_tokens overrides. If a row exists for a callKey, that value
// overrides the hardcoded default in lib/services/ai/aiTokenConfig.ts.
model AiTokenConfig {
  id        Int      @id @default(autoincrement())
  callKey   String   @unique
  maxTokens Int
  updatedAt DateTime @updatedAt
}

// Module SET1 — App Settings (key/value)
//
// Hot-applied settings stored in DB. Reads are cached in-process and the
// cache is invalidated on every write. Designed for credentials + config that
// the user can change from the /settings UI without restarting the dev server.
//
// Conventions:
// - Secret values (e.g. API keys) are stored as-is. SQLite is local-only and
//   the .env.local pattern stores secrets in plaintext on the same disk
//   anyway, so the security boundary is the file system, not the column.
// - Service code reads via getSetting(key) which falls back to process.env.
// - The UI masks secret values to last-4 display.
model AppSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// Module SET1 — AI Usage Log
//
// One row per Anthropic API call. Powers the Usage subsection on the AI
// settings card and the cost estimator's calibration data.
//
// callKey aligns with AI_CALL_DEFINITIONS in aiTokenConfig.ts.
model AiUsageLog {
  id              Int       @id @default(autoincrement())
  callKey         String
  model           String
  inputTokens     Int
  outputTokens   Int
  costUsd         Float
  bidId           Int?
  status          String    @default("ok") // "ok" | "error"
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([callKey])
  @@index([createdAt])
  @@index([bidId])
}
