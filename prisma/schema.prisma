generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Trade {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  costCode    String?
  csiCode     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  bidTrades  BidTrade[]
  subTrades  SubcontractorTrade[]
}

model Bid {
  id          Int       @id @default(autoincrement())
  projectName String
  location    String?
  description String?
  scope       String    @default("")
  status      String    @default("draft")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bidTrades   BidTrade[]
  selections  BidInviteSelection[]
  exportBatches ExportBatch[]
}

model BidTrade {
  id         Int     @id @default(autoincrement())
  bidId      Int
  tradeId    Int
  scopeNotes String?

  bid   Bid   @relation(fields: [bidId], references: [id])
  trade Trade @relation(fields: [tradeId], references: [id])

  @@unique([bidId, tradeId])
}

model Subcontractor {
  id        Int      @id @default(autoincrement())
  company   String
  office    String?
  status    String   @default("active")
  notes     String?
  isUnion   Boolean  @default(false)
  isMWBE    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts   Contact[]
  subTrades  SubcontractorTrade[]
  selections BidInviteSelection[]
}

model SubcontractorTrade {
  id              Int @id @default(autoincrement())
  subcontractorId Int
  tradeId         Int

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
  trade         Trade         @relation(fields: [tradeId], references: [id])

  @@unique([subcontractorId, tradeId])
}

model Contact {
  id              Int      @id @default(autoincrement())
  subcontractorId Int
  name            String
  email           String?
  phone           String?
  title           String?
  isPrimary       Boolean  @default(false)
  createdAt       DateTime @default(now())

  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
}

model BidInviteSelection {
  id              Int      @id @default(autoincrement())
  bidId           Int
  subcontractorId Int
  tradeId         Int?
  notes           String?
  createdAt       DateTime @default(now())

  bid           Bid           @relation(fields: [bidId], references: [id])
  subcontractor Subcontractor @relation(fields: [subcontractorId], references: [id])
}

model ExportBatch {
  id          Int      @id @default(autoincrement())
  bidId       Int
  exportedAt  DateTime @default(now())
  rowCount    Int
  fileName    String

  bid Bid @relation(fields: [bidId], references: [id])
}
